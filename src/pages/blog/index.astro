---
import { getCollection } from 'astro:content';
import Page from '../../components/Page.astro';
import { authorName, getSiteContent, localeMeta, localizePath, normalizeLocale, siteUrl, type SiteLocale } from '../../data/siteContent';
import { getBlogLocaleInfo, type BlogLocale } from '../../utils/blogLocale';

interface Props {
	locale?: SiteLocale;
	path?: string;
}

const locale = normalizeLocale(Astro.props.locale);
const pagePath = Astro.props.path ?? localizePath('/blog/', locale);
const content = getSiteContent(locale).blog;
const siteCopy = getSiteContent(locale);
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const localePosts = posts.filter((post) => getBlogLocaleInfo(post).locale === locale);

const getReadingTime = (raw: string) => {
	const words = raw.trim().split(/\s+/).length;
	return Math.max(1, Math.ceil(words / 200));
};

const localeLabel = content.localeLabel as Record<BlogLocale, string>;

const cards = localePosts.map((post) => {
	const localeInfo = getBlogLocaleInfo(post);
	const searchText = [
		post.data.title,
		post.data.description,
		...post.data.tags,
	].join(' ');
	return {
		post,
		locale: localeInfo.locale,
		link: localizePath(`/blog/${post.slug}/`, locale),
		searchText,
		readingTime: getReadingTime(post.body),
		readingLabel: content.minReadByLocale[localeInfo.locale](getReadingTime(post.body)),
		date: post.data.pubDate.toLocaleDateString(localeMeta[localeInfo.locale].dateLocale, {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		}),
	};
});

const breadcrumbJson = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: siteCopy.nav.home,
			item: new URL(localizePath('/', locale), siteUrl).toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: siteCopy.nav.blog,
			item: new URL(localizePath('/blog/', locale), siteUrl).toString(),
		},
	],
});
const blogCollectionJson = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: content.seoTitle,
	description: content.seoDescription,
	url: new URL(localizePath('/blog/', locale), siteUrl).toString(),
	mainEntity: {
		'@type': 'Blog',
		name: `${authorName} ${content.eyebrow}`,
		url: new URL(localizePath('/blog/', locale), siteUrl).toString(),
		blogPost: cards.map((item) => ({
			'@type': 'BlogPosting',
			headline: item.post.data.title,
			description: item.post.data.description,
			url: new URL(localizePath(`/blog/${item.post.slug}/`, item.locale), siteUrl).toString(),
			datePublished: item.post.data.pubDate.toISOString(),
			dateModified: (item.post.data.updatedDate ?? item.post.data.pubDate).toISOString(),
			inLanguage: item.locale,
			keywords: item.post.data.tags,
		})),
	},
});
---

<Page
	title={content.seoTitle}
	description={content.seoDescription}
	path={pagePath}
	locale={locale}
	layoutVariant="blog-full"
	ogImageAlt={content.ogImageAlt}
>
	<div data-blog-locale-root>
		<section class="blog-hero">
			<p class="eyebrow">{content.eyebrow}</p>
			<h1>{content.heading}</h1>
			<p class="intro">{content.intro}</p>
			<div class="blog-controls">
				<div class="search-field">
					<label class="visually-hidden" for="blog-search">{content.searchLabel}</label>
					<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
						<path d="M10.68 11.74a6 6 0 111.06-1.06l3.29 3.29a.75.75 0 01-1.06 1.06zM11.5 7a4.5 4.5 0 10-9 0 4.5 4.5 0 009 0z"></path>
					</svg>
					<input id="blog-search" type="search" placeholder={content.searchPlaceholder} data-blog-search />
				</div>
			</div>
		</section>

		<section class="blog-list" aria-label={content.postsAria}>
			{cards.map((item) => (
				<article class="post-card" data-post-locale={item.locale} data-post-search={item.searchText.toLowerCase()}>
					<a href={item.link} class="post-link">
						<div class="post-meta">
							<span class="locale-pill">{localeLabel[item.locale]}</span>
							<time datetime={item.post.data.pubDate.toISOString()}>{item.date}</time>
							<span>{item.readingLabel}</span>
						</div>
						<h2 class="post-title">{item.post.data.title}</h2>
						<p class="post-desc">{item.post.data.description}</p>
						<div class="tags">
							{item.post.data.tags.map((tag) => (
								<span class="tag">{tag}</span>
							))}
						</div>
					</a>
				</article>
			))}
			<p class="empty-locale" data-locale-empty hidden></p>
		</section>
	</div>

	<script type="application/ld+json" set:html={breadcrumbJson}></script>
	<script type="application/ld+json" set:html={blogCollectionJson}></script>
</Page>

<style>
	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.blog-hero {
		max-width: 100%;
		margin: 0 0 28px;
	}

	.eyebrow {
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: 10px;
	}

	h1 {
		font-size: clamp(28px, 4vw, 36px);
		letter-spacing: -0.03em;
		line-height: 1.15;
		margin-bottom: 12px;
		max-width: 24ch;
	}

	.intro {
		font-size: 16px;
		line-height: 1.7;
		color: var(--muted);
		max-width: 760px;
		margin-bottom: 14px;
	}

	.blog-controls {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 12px;
		flex-wrap: wrap;
	}

	.search-field {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		min-width: min(420px, 100%);
		min-height: 40px;
		padding: 0 14px;
		border: 1px solid var(--border);
		border-radius: 10px;
		background: var(--surface);
		color: var(--muted);
	}

	.search-field:focus-within {
		border-color: var(--border-strong);
	}

	.search-field input {
		width: 100%;
		min-width: 0;
		border: 0;
		outline: 0;
		background: transparent;
		color: var(--text);
		font-size: 14px;
	}

	.search-field input::placeholder {
		color: var(--muted);
	}

	.post-link:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.blog-list {
		max-width: 100%;
		margin: 0;
		display: grid;
		gap: 10px;
	}

	.post-card {
		border: 1px solid var(--border);
		border-radius: 12px;
		transition: border-color 0.15s ease, background-color 0.15s ease;
	}

	.post-card:hover {
		border-color: var(--border-strong);
		background: var(--surface);
	}

	.post-link {
		display: block;
		padding: 20px 22px;
	}

	.post-meta {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--muted);
		margin-bottom: 8px;
		align-items: center;
	}

	.locale-pill {
		font-size: 11px;
		border: 1px solid var(--border);
		border-radius: 999px;
		color: var(--muted);
		padding: 2px 9px;
	}

	.post-title {
		font-size: 18px;
		letter-spacing: -0.02em;
		line-height: 1.4;
		color: var(--text);
		margin-bottom: 8px;
	}

	.post-desc {
		font-size: 14px;
		line-height: 1.6;
		color: var(--muted);
		margin-bottom: 14px;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.tag {
		font-size: 11px;
		border: 1px solid var(--border);
		border-radius: 999px;
		color: var(--muted);
		padding: 2px 9px;
	}

	.empty-locale {
		font-size: 14px;
		color: var(--muted);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 16px;
	}

	@media (max-width: 768px) {
		h1 {
			font-size: 29px;
		}

		.blog-controls,
		.search-field {
			width: 100%;
		}

		.post-link {
			padding: 16px;
		}

		.post-title {
			font-size: 16px;
		}
	}
</style>

<script is:inline define:vars={{ noMatchesMessage: content.noMatches }}>
	(() => {
		const root = document.querySelector('[data-blog-locale-root]');
		if (!root) return;

		const cards = Array.from(root.querySelectorAll('[data-post-locale]'));
		const emptyState = root.querySelector('[data-locale-empty]');
		const search = root.querySelector('[data-blog-search]');

		const getQueryFromUrl = () => new URL(window.location.href).searchParams.get('q') || '';

		const setStateInUrl = (query) => {
			const url = new URL(window.location.href);
			if (query) {
				url.searchParams.set('q', query);
			} else {
				url.searchParams.delete('q');
			}
			window.history.replaceState({}, '', url);
		};

		const applyFilters = (query) => {
			const normalizedQuery = query.trim().toLowerCase();
			let visible = 0;
			for (const card of cards) {
				const matchesQuery =
					!normalizedQuery ||
					(card.getAttribute('data-post-search') || '').includes(normalizedQuery);
				const matches = matchesQuery;
				card.hidden = !matches;
				if (matches) visible++;
			}

			if (emptyState) {
				emptyState.hidden = visible > 0;
				emptyState.textContent =
					noMatchesMessage;
			}
		};

		const initialQuery = getQueryFromUrl();
		if (search) {
			search.value = initialQuery;
		}
		applyFilters(initialQuery);

		search?.addEventListener('input', () => {
			const query = search.value.trim();
			setStateInUrl(query);
			applyFilters(query);
		});
	})();
</script>
