---
import { getCollection } from 'astro:content';
import Page from '../../components/Page.astro';
import { getBlogLocaleInfo, type BlogLocale } from '../../utils/blogLocale';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const getReadingTime = (raw: string) => {
	const words = raw.trim().split(/\s+/).length;
	return Math.max(1, Math.ceil(words / 200));
};

const localeLabel: Record<BlogLocale, string> = {
	en: 'English',
	id: 'Indonesia',
};

const cards = posts.map((post) => {
	const localeInfo = getBlogLocaleInfo(post);
	return {
		post,
		locale: localeInfo.locale,
		link: `/blog/${post.slug}/?lang=${localeInfo.locale}`,
		readingTime: getReadingTime(post.body),
		date: post.data.pubDate.toLocaleDateString(localeInfo.locale === 'id' ? 'id-ID' : 'en-US', {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		}),
	};
});
---

<Page
	title="Blog | Nabil Rizki Navisa"
	description="Notes on software engineering, project lessons, and practical workflows by Nabil Rizki Navisa."
	path="/blog/"
	layoutVariant="blog-full"
	ogImageAlt="Nabil Rizki Navisa blog article listing in GitHub-inspired dark style."
>
	<div data-blog-locale-root>
		<section class="blog-hero">
			<p class="eyebrow">Blog</p>
			<h1>Technical notes, shipped learnings, and practical guides.</h1>
			<p class="intro">A focused reading space with tutorials and engineering notes from real projects and homelab experiments.</p>
			<div class="locale-switch" aria-label="Blog language">
				<button type="button" class="locale-btn" data-locale-btn="en">English</button>
				<button type="button" class="locale-btn" data-locale-btn="id">Indonesia</button>
			</div>
		</section>

		<section class="blog-list" aria-label="Blog posts">
			{cards.map((item) => (
				<article class="post-card" data-post-locale={item.locale}>
					<a href={item.link} class="post-link">
						<div class="post-meta">
							<span class="locale-pill">{localeLabel[item.locale]}</span>
							<time datetime={item.post.data.pubDate.toISOString()}>{item.date}</time>
							<span>{item.locale === 'id' ? `${item.readingTime} menit baca` : `${item.readingTime} min read`}</span>
						</div>
						<h2 class="post-title">{item.post.data.title}</h2>
						<p class="post-desc">{item.post.data.description}</p>
						<div class="tags">
							{item.post.data.tags.map((tag) => (
								<span class="tag">{tag}</span>
							))}
						</div>
					</a>
				</article>
			))}
			<p class="empty-locale" data-locale-empty hidden></p>
		</section>
	</div>
</Page>

<style>
	.blog-hero {
		max-width: 860px;
		margin: 0 auto 28px;
	}

	.eyebrow {
		font-size: 12px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--gh-text-secondary);
		margin-bottom: 8px;
	}

	h1 {
		font-size: clamp(28px, 5vw, 40px);
		line-height: 1.2;
		margin-bottom: 12px;
	}

	.intro {
		font-size: 16px;
		line-height: 1.7;
		color: var(--gh-text-secondary);
		max-width: 700px;
		margin-bottom: 14px;
	}

	.locale-switch {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		border: 1px solid var(--gh-border);
		border-radius: 999px;
		padding: 3px;
		background: var(--gh-base);
	}

	.locale-btn {
		font: inherit;
		font-size: 12px;
		color: var(--gh-text-secondary);
		border: 1px solid transparent;
		background: transparent;
		border-radius: 999px;
		padding: 4px 10px;
		cursor: pointer;
	}

	.locale-btn.is-active {
		color: var(--gh-text);
		background: var(--gh-surface);
		border-color: var(--gh-border-muted);
	}

	.blog-list {
		max-width: 860px;
		margin: 0 auto;
		display: grid;
		gap: 8px;
	}

	.post-card {
		background: var(--gh-base);
		border: 1px solid var(--gh-border);
		border-radius: 6px;
		transition: border-color 0.15s ease;
	}

	.post-card:hover {
		border-color: var(--gh-accent);
	}

	.post-link {
		display: block;
		padding: 14px 16px;
	}

	.post-meta {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
		font-size: 11px;
		color: var(--gh-text-secondary);
		margin-bottom: 6px;
		align-items: center;
	}

	.locale-pill {
		font-size: 11px;
		background: var(--gh-surface);
		border: 1px solid var(--gh-border-muted);
		color: var(--gh-text-secondary);
		padding: 1px 8px;
		border-radius: 20px;
	}

	.post-title {
		font-size: 14px;
		line-height: 1.45;
		color: var(--gh-accent);
		margin-bottom: 8px;
	}

	.post-desc {
		font-size: 12px;
		line-height: 1.5;
		color: var(--gh-text-secondary);
		margin-bottom: 12px;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.tag {
		font-size: 11px;
		background: var(--gh-surface);
		border: 1px solid var(--gh-border-muted);
		color: var(--gh-text-secondary);
		padding: 1px 8px;
		border-radius: 20px;
	}

	.empty-locale {
		font-size: 13px;
		color: var(--gh-text-secondary);
		border: 1px dashed var(--gh-border-muted);
		border-radius: 6px;
		padding: 12px;
	}

	@media (max-width: 768px) {
		.post-link {
			padding: 14px;
		}

		.post-title {
			font-size: 13px;
		}
	}
</style>

<script is:inline>
	(() => {
		const root = document.querySelector('[data-blog-locale-root]');
		if (!root) return;

		const buttons = Array.from(root.querySelectorAll('[data-locale-btn]'));
		const cards = Array.from(root.querySelectorAll('[data-post-locale]'));
		const emptyState = root.querySelector('[data-locale-empty]');

		const getLangFromUrl = () => {
			const current = new URL(window.location.href).searchParams.get('lang');
			return current === 'id' ? 'id' : 'en';
		};

		const setLangInUrl = (lang) => {
			const url = new URL(window.location.href);
			url.searchParams.set('lang', lang);
			window.history.replaceState({}, '', url);
		};

		const applyLocale = (lang) => {
			let visible = 0;
			for (const card of cards) {
				const matches = card.getAttribute('data-post-locale') === lang;
				card.hidden = !matches;
				if (matches) visible++;
			}

			for (const button of buttons) {
				button.classList.toggle('is-active', button.getAttribute('data-locale-btn') === lang);
			}

			if (emptyState) {
				emptyState.hidden = visible > 0;
				emptyState.textContent =
					lang === 'id'
						? 'Belum ada artikel Bahasa Indonesia yang tersedia.'
						: 'No English articles are available yet.';
			}
		};

		const initialLang = getLangFromUrl();
		applyLocale(initialLang);

		for (const button of buttons) {
			button.addEventListener('click', () => {
				const lang = button.getAttribute('data-locale-btn');
				if (lang !== 'en' && lang !== 'id') return;
				setLangInUrl(lang);
				applyLocale(lang);
			});
		}
	})();
</script>
