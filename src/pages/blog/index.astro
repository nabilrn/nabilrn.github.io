---
import { getCollection } from 'astro:content';
import Page from '../../components/Page.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const getReadingTime = (raw: string) => {
	const words = raw.trim().split(/\s+/).length;
	return Math.max(1, Math.ceil(words / 200));
};
---

<Page title="Blog | Nabil Rizki Navisa" description="Notes on software engineering, project lessons, and practical workflows by Nabil Rizki Navisa." path="/blog/">
	<!-- Tab Bar -->
	<div class="tab-bar">
		<a href="/" class="tab">
			<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M0 1.75A.75.75 0 01.75 1h4.253c1.227 0 2.317.59 3 1.501A3.744 3.744 0 0111.006 1h4.245a.75.75 0 01.75.75v10.5a.75.75 0 01-.75.75h-4.507a2.25 2.25 0 00-1.591.659l-.622.621a.75.75 0 01-1.06 0l-.622-.621A2.25 2.25 0 005.258 13H.75a.75.75 0 01-.75-.75zm7.251 10.324l.004-5.073-.002-2.253A2.25 2.25 0 005.003 2.5H1.5v9h3.757a3.75 3.75 0 011.994.574zM8.755 4.75l-.004 7.322a3.752 3.752 0 011.992-.572H14.5v-9h-3.495a2.25 2.25 0 00-2.25 2.25z"></path></svg>
			Overview
		</a>
		<a href="/#showcase" class="tab">
			<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"></path></svg>
			Showcase
		</a>
		<a href="/#projects" class="tab">
			<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5zm10.5-1h-8a1 1 0 00-1 1v6.708A2.486 2.486 0 014.5 9h8zM5 12.25v3.25a.25.25 0 00.4.2l1.45-1.087a.25.25 0 01.3 0L8.6 15.7a.25.25 0 00.4-.2v-3.25a.25.25 0 00-.25-.25h-3.5a.25.25 0 00-.25.25z"></path></svg>
			Projects
		</a>
		<a href="/blog/" class="tab active">
			<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M11.93 8.5a4.002 4.002 0 01-7.86 0H.75a.75.75 0 010-1.5h3.32a4.002 4.002 0 017.86 0h3.32a.75.75 0 010 1.5zm-1.43-.75a2.5 2.5 0 10-5 0 2.5 2.5 0 005 0z"></path></svg>
			Blog
			<span class="tab-badge">{posts.length}</span>
		</a>
	</div>

	<p class="page-desc">Notes on software engineering, project lessons, and practical workflows.</p>

	<div class="blog-list">
		{posts.map((post) => (
			<a href={`/blog/${post.slug}/`} class="blog-card">
				<div class="blog-card-body">
					<div class="blog-card-title">{post.data.title}</div>
					<div class="blog-card-desc">{post.data.description}</div>
					<div class="blog-card-meta">
						<span>{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
						<span>{getReadingTime(post.body)} min read</span>
						{post.data.tags.map((tag) => (
							<span class="pill">{tag}</span>
						))}
					</div>
				</div>
			</a>
		))}
	</div>
</Page>

<style>
	.tab-bar {
		display: flex;
		border-bottom: 1px solid var(--gh-border);
		margin-bottom: 20px;
	}

	.tab {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 8px 14px;
		font-size: 12px;
		color: var(--gh-text-secondary);
		text-decoration: none;
		border-bottom: 2px solid transparent;
		margin-bottom: -1px;
		transition: color 0.15s ease;
	}

	.tab:hover {
		color: var(--gh-text);
	}

	.tab.active {
		color: var(--gh-text);
		border-bottom-color: var(--gh-red);
	}

	.tab svg {
		opacity: 0.7;
	}

	.tab-badge {
		font-size: 11px;
		background: var(--gh-surface-2);
		border-radius: 20px;
		padding: 1px 7px;
		color: var(--gh-text-secondary);
	}

	.page-desc {
		font-size: 14px;
		color: var(--gh-text-secondary);
		margin-bottom: 16px;
	}

	.blog-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.blog-card {
		background: var(--gh-base);
		border: 1px solid var(--gh-border);
		border-radius: 6px;
		padding: 14px 16px;
		display: flex;
		gap: 12px;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.15s ease;
	}

	.blog-card:hover {
		border-color: var(--gh-accent);
	}

	.blog-card-title {
		font-size: 13px;
		font-weight: 600;
		color: var(--gh-accent);
		margin-bottom: 4px;
	}

	.blog-card-desc {
		font-size: 12px;
		color: var(--gh-text-secondary);
		margin-bottom: 8px;
		line-height: 1.5;
	}

	.blog-card-meta {
		display: flex;
		gap: 10px;
		align-items: center;
		font-size: 11px;
		color: var(--gh-text-secondary);
		flex-wrap: wrap;
	}

	.pill {
		font-size: 11px;
		background: var(--gh-surface);
		border: 1px solid var(--gh-border-muted);
		border-radius: 20px;
		padding: 1px 8px;
		color: var(--gh-text-secondary);
	}
</style>
