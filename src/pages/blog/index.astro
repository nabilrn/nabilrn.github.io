---
import { getCollection } from 'astro:content';
import Page from '../../components/Page.astro';
import Icon from '../../components/Icon.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const getReadingTime = (raw: string) => {
	const words = raw.trim().split(/\s+/).length;
	return Math.max(1, Math.ceil(words / 200));
};
---

<Page>
	<section>
		<h2>Blog</h2>
		<p>Notes on software engineering, project lessons, and practical workflows.</p>
	</section>

	<section class="blog-list">
		{posts.map((post) => (
			<a href={`/blog/${post.slug}/`} class="blog-card">
				<div class="card-body">
					<h3 class="post-title">{post.data.title}</h3>
					<div class="post-meta"><time datetime={post.data.pubDate.toISOString()} class="post-date">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time> <span class="reading"><span class="badge small"><Icon name="clock" /> {getReadingTime(post.body)} min</span></span></div>
					<div class="tags">{post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}</div>
					<p class="post-desc">{post.data.description}</p>
				</div>
			</a>
		))}
	</section>
</Page>

<style>
	.blog-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.blog-card {
		display: block;
		border: 1px solid var(--muted, #e6e6e6);
		padding: 1rem;
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		transition: box-shadow .12s ease, transform .08s ease;
	}
	.blog-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.06); transform: translateY(-3px); }
	.post-title { margin: 0 0 .25rem 0; font-size: 1.1rem; }
	.post-meta{display:flex;gap:0.5rem;align-items:center;color:var(--sl-color-gray-3);margin-bottom:.5rem}
	.post-date{font-size:0.9rem;color:var(--sl-color-gray-4)}
	.tags { margin-bottom: .5rem; color: var(--muted, #6b6b6b); }
	.tag { margin-right: .5rem; font-family: monospace; }
	.post-desc { margin: 0; color: var(--muted, #444); }
</style>
