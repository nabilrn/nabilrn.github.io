---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Page from '../../components/Page.astro';
import EngagementBar from '../../components/EngagementBarNew.astro';
import { getBlogLocaleInfo, getTranslationVariants, type BlogLocale } from '../../utils/blogLocale';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props as { post: CollectionEntry<'blog'> };
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const { Content } = await render(post);
const localeInfo = getBlogLocaleInfo(post);
const locale: BlogLocale = localeInfo.locale;
const variants = getTranslationVariants(allPosts, localeInfo.translationKey);

const words = post.body.trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 200));
const dateLocale = locale === 'id' ? 'id-ID' : 'en-US';
const dateStr = post.data.pubDate.toLocaleDateString(dateLocale, { year: 'numeric', month: 'short', day: 'numeric' });

const siteUrl = 'https://nabilrizkinavisa.me';
const postPath = `/blog/${post.slug}/`;
const postUrl = `${siteUrl}${postPath}`;
const ogImagePath = `/og/blog/${post.slug}.png`;
const ogImageUrl = `${siteUrl}${ogImagePath}`;
const publishedTime = post.data.pubDate.toISOString();
const modifiedTime = (post.data.updatedDate ?? post.data.pubDate).toISOString();

const labels =
	locale === 'id'
		? {
				back: '← Kembali ke semua artikel',
				minRead: `${readingTime} menit baca`,
				updated: 'Diperbarui',
		  }
		: {
				back: '← Back to all articles',
				minRead: `${readingTime} min read`,
				updated: 'Updated',
		  };

const languageOptions: Array<{ locale: BlogLocale; label: string; href?: string }> = [
	{
		locale: 'en',
		label: 'English',
		href: variants.en ? `/blog/${variants.en.slug}/?lang=en` : undefined,
	},
	{
		locale: 'id',
		label: 'Indonesia',
		href: variants.id ? `/blog/${variants.id.slug}/?lang=id` : undefined,
	},
];

const breadcrumbJson = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Home',
			item: siteUrl,
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Blog',
			item: `${siteUrl}/blog/`,
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: post.data.title,
			item: postUrl,
		},
	],
});

const blogPostingJson = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: post.data.title,
	description: post.data.description,
	image: ogImageUrl,
	datePublished: publishedTime,
	dateModified: modifiedTime,
	inLanguage: locale,
	author: {
		'@type': 'Person',
		name: 'Nabil Rizki Navisa',
		url: siteUrl,
	},
	publisher: {
		'@type': 'Person',
		name: 'Nabil Rizki Navisa',
		url: siteUrl,
	},
	mainEntityOfPage: postUrl,
	url: postUrl,
	keywords: post.data.tags,
});
---

<Page
	title={`${post.data.title} | Nabil Rizki Navisa`}
	description={post.data.description}
	path={postPath}
	lang={locale}
	layoutVariant="blog-full"
	ogImage={ogImagePath}
	ogImageAlt={`Social preview card for article: ${post.data.title}`}
	ogType="article"
	twitterCard="summary"
	publishedTime={publishedTime}
	modifiedTime={modifiedTime}
	articleTags={post.data.tags}
	ogImageWidth={1200}
	ogImageHeight={1200}
>
	<div class="post-layout">
		<article class="post-main">
			<div class="top-row">
				<a href={`/blog/?lang=${locale}`} class="back-link" aria-label={labels.back}>{labels.back}</a>
				<div class="lang-switch" aria-label="Article language">
					{languageOptions.map((option) =>
						option.href ? (
							<a class={`lang-btn ${option.locale === locale ? 'is-active' : ''}`} href={option.href}>
								{option.label}
							</a>
						) : (
							<span class="lang-btn is-disabled">{option.label}</span>
						)
					)}
				</div>
			</div>

			<header class="post-header">
				<h1>{post.data.title}</h1>
				<div class="post-meta">
					<span>{dateStr}</span>
					<span>{labels.minRead}</span>
					{post.data.updatedDate && <span>{labels.updated} {post.data.updatedDate.toLocaleDateString(dateLocale, { year: 'numeric', month: 'short', day: 'numeric' })}</span>}
				</div>
				<div class="post-tags">
					{post.data.tags.map((tag: string) => (
						<span class="tag">{tag}</span>
					))}
				</div>
			</header>

			<div class="post-content">
				<Content />
			</div>
		</article>

		<aside class="post-rail" aria-label="Engagement actions">
			<EngagementBar postId={post.slug} title={post.data.title} variant="floating" />
		</aside>
	</div>

	<script type="application/ld+json" set:html={breadcrumbJson}></script>
	<script type="application/ld+json" set:html={blogPostingJson}></script>
</Page>

<style>
	.post-layout {
		max-width: 1080px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: minmax(0, 1fr) 88px;
		gap: 30px;
		align-items: start;
	}

	.post-main {
		max-width: 780px;
		min-width: 0;
	}

	.top-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 14px;
		flex-wrap: wrap;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 13px;
		color: var(--gh-text-secondary);
	}

	.back-link:hover {
		color: var(--gh-accent-hover);
	}

	.lang-switch {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		border: 1px solid var(--gh-border);
		border-radius: 999px;
		padding: 3px;
		background: var(--gh-base);
	}

	.lang-btn {
		font-size: 12px;
		color: var(--gh-text-secondary);
		border: 1px solid transparent;
		background: transparent;
		border-radius: 999px;
		padding: 4px 10px;
	}

	.lang-btn.is-active {
		color: var(--gh-text);
		background: var(--gh-surface);
		border-color: var(--gh-border-muted);
	}

	.lang-btn.is-disabled {
		opacity: 0.45;
		pointer-events: none;
	}

	.post-header {
		margin-bottom: 22px;
		padding-bottom: 18px;
		border-bottom: 1px solid var(--gh-border);
	}

	.post-header h1 {
		font-size: clamp(30px, 5vw, 44px);
		line-height: 1.18;
		margin-bottom: 12px;
		letter-spacing: -0.01em;
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 8px 14px;
		font-size: 13px;
		color: var(--gh-text-secondary);
		margin-bottom: 12px;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.tag {
		font-size: 11px;
		border: 1px solid var(--gh-border-muted);
		background: var(--gh-surface);
		color: var(--gh-text-secondary);
		padding: 2px 10px;
		border-radius: 999px;
	}

	.post-content :global(p) {
		font-size: 17px;
		line-height: 1.85;
		margin-bottom: 1.1em;
		color: var(--gh-text-body);
	}

	.post-content :global(h2) {
		font-size: clamp(24px, 3vw, 30px);
		line-height: 1.3;
		margin: 2.2em 0 0.8em;
	}

	.post-content :global(h3) {
		font-size: clamp(20px, 2.4vw, 24px);
		line-height: 1.35;
		margin: 1.8em 0 0.7em;
	}

	.post-content :global(ul),
	.post-content :global(ol) {
		margin: 0 0 1.2em;
		padding-left: 1.5em;
	}

	.post-content :global(li) {
		font-size: 17px;
		line-height: 1.8;
		color: var(--gh-text-body);
		margin-bottom: 0.35em;
	}

	.post-content :global(a) {
		color: var(--gh-accent-hover);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.post-content :global(blockquote) {
		margin: 1.2em 0;
		padding: 0.2em 0 0.2em 1em;
		border-left: 3px solid var(--gh-border-muted);
		color: var(--gh-text-secondary);
	}

	.post-content :global(code) {
		font-size: 14px;
		background: var(--gh-surface);
		padding: 2px 6px;
		border-radius: 6px;
		border: 1px solid var(--gh-border);
	}

	.post-content :global(pre) {
		background: var(--gh-surface);
		border: 1px solid var(--gh-border);
		border-radius: 8px;
		padding: 14px;
		overflow-x: auto;
		margin: 0 0 1.2em;
	}

	.post-content :global(pre code) {
		border: none;
		background: none;
		padding: 0;
	}

	.post-content :global(img) {
		border-radius: 10px;
		border: 1px solid var(--gh-border);
		margin: 1.2em 0;
	}

	.post-content :global(hr) {
		border: none;
		border-top: 1px solid var(--gh-border);
		margin: 2em 0;
	}

	.post-rail {
		position: relative;
	}

	@media (max-width: 980px) {
		.post-layout {
			grid-template-columns: minmax(0, 1fr);
			gap: 16px;
		}
	}

	@media (max-width: 768px) {
		.post-content :global(p),
		.post-content :global(li) {
			font-size: 16px;
			line-height: 1.78;
		}
	}
</style>
