---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Page from '../../components/Page.astro';
import EngagementBar from '../../components/EngagementBarNew.astro';
import { authorName, getSiteContent, localeMeta, localizePath, normalizeLocale, siteUrl, type SiteLocale } from '../../data/siteContent';
import { getBlogLocaleInfo, getTranslationVariants, type BlogLocale } from '../../utils/blogLocale';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);
	return posts
		.filter((post) => getBlogLocaleInfo(post).locale === 'en')
		.map((post) => ({
			params: { slug: post.slug },
			props: { post },
		}));
}

const { post, locale: rawUiLocale, path: rawPath } = Astro.props as { post: CollectionEntry<'blog'>; locale?: SiteLocale; path?: string };
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const { Content } = await render(post);
const localeInfo = getBlogLocaleInfo(post);
const postLocale: BlogLocale = localeInfo.locale;
const uiLocale = normalizeLocale(rawUiLocale ?? postLocale);
const variants = getTranslationVariants(allPosts, localeInfo.translationKey);
const blogLocales = ['en', 'id', 'cn', 'jp'] as const satisfies readonly BlogLocale[];

const words = post.body.trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 200));
const dateLocale = localeMeta[postLocale].dateLocale;
const dateStr = post.data.pubDate.toLocaleDateString(dateLocale, { year: 'numeric', month: 'short', day: 'numeric' });

const siteCopy = getSiteContent(uiLocale);
const blogCopy = siteCopy.blog;
const postPath = rawPath ?? localizePath(`/blog/${post.slug}/`, uiLocale);
const postUrl = new URL(postPath, siteUrl).toString();
const ogImagePath = `/og/blog/${post.slug}.png`;
const ogImageUrl = `${siteUrl}${ogImagePath}`;
const publishedTime = post.data.pubDate.toISOString();
const modifiedTime = (post.data.updatedDate ?? post.data.pubDate).toISOString();

const labels = {
	back: `← ${blogCopy.article.back}`,
	minRead: blogCopy.minReadByLocale[postLocale](readingTime),
	updated: blogCopy.article.updated,
};

const alternatePaths = Object.fromEntries(
	blogLocales
		.filter((optionLocale) => variants[optionLocale])
		.map((optionLocale) => [
			optionLocale,
			localizePath(`/blog/${variants[optionLocale]!.slug}/`, optionLocale),
		])
) as Partial<Record<SiteLocale, string>>;

const breadcrumbJson = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: siteCopy.nav.home,
			item: new URL(localizePath('/', uiLocale), siteUrl).toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: siteCopy.nav.blog,
			item: new URL(localizePath('/blog/', uiLocale), siteUrl).toString(),
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: post.data.title,
			item: postUrl,
		},
	],
});

const blogPostingJson = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: post.data.title,
	description: post.data.description,
	image: ogImageUrl,
	datePublished: publishedTime,
	dateModified: modifiedTime,
	inLanguage: postLocale,
	author: {
		'@type': 'Person',
		name: authorName,
		url: siteUrl,
	},
	publisher: {
		'@type': 'Person',
		name: authorName,
		url: siteUrl,
	},
	mainEntityOfPage: postUrl,
	url: postUrl,
	keywords: post.data.tags,
});
---

<Page
	title={`${post.data.title} | ${authorName}`}
	description={post.data.description}
	path={postPath}
	locale={uiLocale}
	lang={postLocale}
	layoutVariant="blog-full"
	ogImage={ogImagePath}
	ogImageAlt={blogCopy.article.ogImageAlt(post.data.title)}
	ogType="article"
	twitterCard="summary_large_image"
	publishedTime={publishedTime}
	modifiedTime={modifiedTime}
	articleTags={post.data.tags}
	ogImageWidth={1200}
	ogImageHeight={630}
	alternatePaths={alternatePaths}
>
	<div class="post-layout">
		<article class="post-main">
			<div class="top-row">
				<a href={localizePath('/blog/', uiLocale)} class="back-link" aria-label={labels.back}>{labels.back}</a>
			</div>

			<header class="post-header">
				<h1>{post.data.title}</h1>
				<div class="post-meta">
					<span>{dateStr}</span>
					<span>{labels.minRead}</span>
					{post.data.updatedDate && <span>{labels.updated} {post.data.updatedDate.toLocaleDateString(dateLocale, { year: 'numeric', month: 'short', day: 'numeric' })}</span>}
				</div>
				<div class="post-tags">
					{post.data.tags.map((tag: string) => (
						<span class="tag">{tag}</span>
					))}
				</div>
			</header>

			<div class="post-content">
				<Content />
			</div>
		</article>

		<aside class="post-rail" aria-label={blogCopy.article.engagementAria}>
			<EngagementBar postId={post.slug} title={post.data.title} variant="floating" locale={uiLocale} />
		</aside>
	</div>

	<script type="application/ld+json" set:html={breadcrumbJson}></script>
	<script type="application/ld+json" set:html={blogPostingJson}></script>
</Page>

<style>
	.post-layout {
		max-width: 1080px;
		margin: 0;
		display: grid;
		grid-template-columns: minmax(0, 1fr) 88px;
		gap: 30px;
		align-items: start;
	}

	.post-main {
		max-width: 780px;
		min-width: 0;
	}

	.top-row {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 12px;
		margin-bottom: 14px;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 13px;
		color: var(--muted);
		transition: color 0.15s ease;
	}

	.back-link:hover {
		color: var(--text);
	}

	.post-header {
		margin-bottom: 22px;
		padding-bottom: 18px;
		border-bottom: 1px solid var(--border);
	}

	.post-header h1 {
		font-size: clamp(30px, 5vw, 44px);
		line-height: 1.18;
		margin-bottom: 12px;
		letter-spacing: -0.01em;
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 8px 14px;
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--muted);
		margin-bottom: 12px;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.tag {
		font-size: 11px;
		border: 1px solid var(--border);
		border-radius: 999px;
		color: var(--muted);
		padding: 2px 9px;
	}

	.post-content :global(p) {
		font-family: var(--font-sans);
		font-size: 16px;
		line-height: 1.85;
		margin-bottom: 1.1em;
		color: var(--text-body);
	}

	.post-content :global(h2) {
		font-size: clamp(24px, 3vw, 30px);
		line-height: 1.3;
		margin: 2.2em 0 0.8em;
	}

	.post-content :global(h3) {
		font-size: clamp(20px, 2.4vw, 24px);
		line-height: 1.35;
		margin: 1.8em 0 0.7em;
	}

	.post-content :global(ul),
	.post-content :global(ol) {
		margin: 0 0 1.2em;
		padding-left: 1.5em;
	}

	.post-content :global(li) {
		font-family: var(--font-sans);
		font-size: 16px;
		line-height: 1.8;
		color: var(--text-body);
		margin-bottom: 0.35em;
	}

	.post-content :global(a) {
		color: var(--accent-hover);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.post-content :global(blockquote) {
		margin: 1.2em 0;
		padding: 0.2em 0 0.2em 1em;
		border-left: 2px solid var(--border-strong);
		color: var(--muted);
	}

	.post-content :global(code) {
		font-size: 14px;
		background: var(--surface-2);
		padding: 2px 6px;
		border-radius: 6px;
		border: 1px solid var(--border);
	}

	.post-content :global(pre) {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 10px;
		padding: 16px;
		overflow-x: auto;
		margin: 0 0 1.2em;
	}

	.post-content :global(pre code) {
		border: none;
		background: none;
		padding: 0;
	}

	.post-content :global(img) {
		border-radius: 10px;
		border: 1px solid var(--border);
		margin: 1.2em 0;
	}

	.post-content :global(hr) {
		border: none;
		border-top: 1px solid var(--border);
		margin: 2em 0;
	}

	.post-rail {
		position: relative;
	}

	@media (max-width: 980px) {
		.post-layout {
			grid-template-columns: minmax(0, 1fr);
			gap: 16px;
		}
	}

	@media (max-width: 768px) {
		.post-content :global(p),
		.post-content :global(li) {
			font-size: 16px;
			line-height: 1.78;
		}
	}
</style>
