---
import { getCollection, render } from 'astro:content';
import Page from '../../components/Page.astro';
import EngagementBar from '../../components/EngagementBarNew.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const words = post.body.trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 200));
const dateStr = post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Page title={`${post.data.title} | Nabil Rizki Navisa`} description={post.data.description} path={`/blog/${post.slug}/`}>
	<!-- Tab Bar -->
	<div class="tab-bar">
		<a href="/" class="tab">
			<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M0 1.75A.75.75 0 01.75 1h4.253c1.227 0 2.317.59 3 1.501A3.744 3.744 0 0111.006 1h4.245a.75.75 0 01.75.75v10.5a.75.75 0 01-.75.75h-4.507a2.25 2.25 0 00-1.591.659l-.622.621a.75.75 0 01-1.06 0l-.622-.621A2.25 2.25 0 005.258 13H.75a.75.75 0 01-.75-.75zm7.251 10.324l.004-5.073-.002-2.253A2.25 2.25 0 005.003 2.5H1.5v9h3.757a3.75 3.75 0 011.994.574zM8.755 4.75l-.004 7.322a3.752 3.752 0 011.992-.572H14.5v-9h-3.495a2.25 2.25 0 00-2.25 2.25z"></path></svg>
			Overview
		</a>
		<a href="/#showcase" class="tab">
			<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"></path></svg>
			Showcase
		</a>
		<a href="/#projects" class="tab">
			<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5zm10.5-1h-8a1 1 0 00-1 1v6.708A2.486 2.486 0 014.5 9h8zM5 12.25v3.25a.25.25 0 00.4.2l1.45-1.087a.25.25 0 01.3 0L8.6 15.7a.25.25 0 00.4-.2v-3.25a.25.25 0 00-.25-.25h-3.5a.25.25 0 00-.25.25z"></path></svg>
			Projects
		</a>
		<a href="/blog/" class="tab active">
			<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M11.93 8.5a4.002 4.002 0 01-7.86 0H.75a.75.75 0 010-1.5h3.32a4.002 4.002 0 017.86 0h3.32a.75.75 0 010 1.5zm-1.43-.75a2.5 2.5 0 10-5 0 2.5 2.5 0 005 0z"></path></svg>
			Blog
		</a>
	</div>

	<div class="breadcrumb">
		<a href="/blog/">Blog</a> / <span>{post.data.title}</span>
	</div>

	<div class="post-header">
		<h1 class="post-title">{post.data.title}</h1>
		<div class="post-author-row">
			<span class="author-name">Nabil Rizki Navisa</span>
			<span class="author-meta">{dateStr}</span>
			<span class="author-meta">{readingTime} min read</span>
		</div>
		<div class="post-tags">
			{post.data.tags.map((tag: string) => (
				<span class="pill">{tag}</span>
			))}
		</div>
	</div>

	<EngagementBar postId={post.slug} title={post.data.title} />

	<!-- BreadcrumbList JSON-LD -->
	<script type="application/ld+json" is:inline>
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{
				"@type": "ListItem",
				"position": 1,
				"name": "Home",
				"item": "https://nabilrizkinavisa.me"
			},
			{
				"@type": "ListItem",
				"position": 2,
				"name": "Blog",
				"item": "https://nabilrizkinavisa.me/blog/"
			},
			{
				"@type": "ListItem",
				"position": 3,
				"name": {post.data.title},
				"item": `https://nabilrizkinavisa.me/blog/${post.slug}/`
			}
		]
	}
	</script>
	<!-- Article JSON-LD -->
	<script type="application/ld+json" is:inline>
	{
		"@context": "https://schema.org",
		"@type": "Article",
		"headline": {post.data.title},
		"description": {post.data.description},
		"author": {
			"@type": "Person",
			"name": "Nabil Rizki Navisa",
			"url": "https://nabilrizkinavisa.me"
		},
		"publisher": {
			"@type": "Person",
			"name": "Nabil Rizki Navisa",
			"url": "https://nabilrizkinavisa.me"
		},
		"datePublished": {post.data.pubDate.toISOString()},
		"url": `https://nabilrizkinavisa.me/blog/${post.slug}/`,
		"mainEntityOfPage": `https://nabilrizkinavisa.me/blog/${post.slug}/`,
		"keywords": {post.data.tags}
	}
	</script>

	<div class="post-body">
		<Content />
	</div>
</Page>

<style>
	.tab-bar {
		display: flex;
		border-bottom: 1px solid var(--gh-border);
		margin-bottom: 20px;
	}

	.tab {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 8px 14px;
		font-size: 12px;
		color: var(--gh-text-secondary);
		text-decoration: none;
		border-bottom: 2px solid transparent;
		margin-bottom: -1px;
		transition: color 0.15s ease;
	}

	.tab:hover {
		color: var(--gh-text);
	}

	.tab.active {
		color: var(--gh-text);
		border-bottom-color: var(--gh-red);
	}

	.tab svg {
		opacity: 0.7;
	}

	.breadcrumb {
		font-size: 12px;
		color: var(--gh-text-secondary);
		margin-bottom: 16px;
	}

	.breadcrumb a {
		color: var(--gh-accent);
		text-decoration: none;
	}

	.breadcrumb a:hover {
		text-decoration: underline;
	}

	.post-header {
		border: 1px solid var(--gh-border);
		border-radius: 6px;
		padding: 16px;
		margin-bottom: 12px;
	}

	.post-title {
		font-size: 20px;
		font-weight: 600;
		color: var(--gh-text);
		line-height: 1.4;
		margin-bottom: 10px;
	}

	.post-author-row {
		display: flex;
		align-items: center;
		gap: 8px;
		margin-bottom: 12px;
	}

	.author-name {
		font-size: 12px;
		font-weight: 600;
		color: var(--gh-text);
	}

	.author-meta {
		font-size: 12px;
		color: var(--gh-text-secondary);
	}

	.post-tags {
		display: flex;
		gap: 4px;
		flex-wrap: wrap;
	}

	.pill {
		font-size: 11px;
		background: var(--gh-surface);
		border: 1px solid var(--gh-border-muted);
		border-radius: 20px;
		padding: 1px 8px;
		color: var(--gh-text-secondary);
	}

	.post-body {
		border: 1px solid var(--gh-border);
		border-radius: 6px;
		padding: 20px;
		margin-top: 12px;
	}

	.post-body :global(p) {
		font-size: 14px;
		line-height: 1.7;
		color: var(--gh-text-body);
		margin-bottom: 14px;
	}

	.post-body :global(p:last-child) {
		margin-bottom: 0;
	}

	.post-body :global(strong) {
		color: var(--gh-text);
		font-weight: 600;
	}

	.post-body :global(h2) {
		font-size: 16px;
		font-weight: 600;
		color: var(--gh-text);
		margin: 24px 0 12px 0;
		padding-bottom: 8px;
		border-bottom: 1px solid var(--gh-border);
	}

	.post-body :global(h3) {
		font-size: 14px;
		font-weight: 600;
		color: var(--gh-text);
		margin: 20px 0 8px 0;
	}

	.post-body :global(a) {
		color: var(--gh-accent);
		text-decoration: none;
	}

	.post-body :global(a:hover) {
		text-decoration: underline;
	}

	.post-body :global(ul),
	.post-body :global(ol) {
		padding-left: 20px;
		margin: 0 0 14px 0;
	}

	.post-body :global(li) {
		font-size: 14px;
		color: var(--gh-text-body);
		line-height: 1.7;
		margin-bottom: 6px;
	}

	.post-body :global(code) {
		font-size: 13px;
		background: var(--gh-surface);
		padding: 2px 6px;
		border-radius: 6px;
		border: 1px solid var(--gh-border);
	}

	.post-body :global(pre) {
		background: var(--gh-surface);
		border: 1px solid var(--gh-border);
		border-radius: 6px;
		padding: 14px;
		overflow-x: auto;
		margin: 0 0 14px 0;
	}

	.post-body :global(pre code) {
		background: none;
		border: none;
		padding: 0;
	}

	.post-body :global(blockquote) {
		border-left: 3px solid var(--gh-border-muted);
		padding-left: 14px;
		color: var(--gh-text-secondary);
		margin: 0 0 14px 0;
	}

	.post-body :global(img) {
		border-radius: 6px;
		border: 1px solid var(--gh-border);
	}

	.post-body :global(hr) {
		border: none;
		border-top: 1px solid var(--gh-border);
		margin: 24px 0;
	}
</style>
