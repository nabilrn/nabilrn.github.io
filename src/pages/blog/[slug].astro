---
import { getCollection, render } from 'astro:content';
import Page from '../../components/Page.astro';
import EngagementBar from '../../components/EngagementBarNew.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const words = post.body.trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 200));
const dateStr = post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Page title={`${post.data.title} | Nabil Rizki Navisa`} description={post.data.description} path={`/blog/${post.slug}/`}>
	<div class="breadcrumb">
		<a href="/blog/">Blog</a> / <span>{post.data.title}</span>
	</div>

	<div class="post-header">
		<h1 class="post-title">{post.data.title}</h1>
		<div class="post-author-row">
			<span class="author-name">Nabil Rizki Navisa</span>
			<span class="author-meta">{dateStr}</span>
			<span class="author-meta">{readingTime} min read</span>
		</div>
		<div class="post-tags">
			{post.data.tags.map((tag: string) => (
				<span class="pill">{tag}</span>
			))}
		</div>
	</div>

	<EngagementBar postId={post.slug} title={post.data.title} />

	<!-- BreadcrumbList JSON-LD -->
	<script type="application/ld+json" is:inline>
	{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{
				"@type": "ListItem",
				"position": 1,
				"name": "Home",
				"item": "https://nabilrizkinavisa.me"
			},
			{
				"@type": "ListItem",
				"position": 2,
				"name": "Blog",
				"item": "https://nabilrizkinavisa.me/blog/"
			},
			{
				"@type": "ListItem",
				"position": 3,
				"name": {post.data.title},
				"item": `https://nabilrizkinavisa.me/blog/${post.slug}/`
			}
		]
	}
	</script>
	<!-- Article JSON-LD -->
	<script type="application/ld+json" is:inline>
	{
		"@context": "https://schema.org",
		"@type": "Article",
		"headline": {post.data.title},
		"description": {post.data.description},
		"author": {
			"@type": "Person",
			"name": "Nabil Rizki Navisa",
			"url": "https://nabilrizkinavisa.me"
		},
		"publisher": {
			"@type": "Person",
			"name": "Nabil Rizki Navisa",
			"url": "https://nabilrizkinavisa.me"
		},
		"datePublished": {post.data.pubDate.toISOString()},
		"url": `https://nabilrizkinavisa.me/blog/${post.slug}/`,
		"mainEntityOfPage": `https://nabilrizkinavisa.me/blog/${post.slug}/`,
		"keywords": {post.data.tags}
	}
	</script>

	<div class="post-body">
		<Content />
	</div>
</Page>

<style>
	.breadcrumb {
		font-size: 12px;
		color: var(--gh-text-secondary);
		margin-bottom: 16px;
	}

	.breadcrumb a {
		color: var(--gh-accent);
		text-decoration: none;
	}

	.breadcrumb a:hover {
		text-decoration: underline;
	}

	.post-header {
		border: 1px solid var(--gh-border);
		border-radius: 6px;
		padding: 16px;
		margin-bottom: 12px;
	}

	.post-title {
		font-size: 20px;
		font-weight: 600;
		color: var(--gh-text);
		line-height: 1.4;
		margin-bottom: 10px;
	}

	.post-author-row {
		display: flex;
		align-items: center;
		gap: 8px;
		margin-bottom: 12px;
	}

	.author-name {
		font-size: 12px;
		font-weight: 600;
		color: var(--gh-text);
	}

	.author-meta {
		font-size: 12px;
		color: var(--gh-text-secondary);
	}

	.post-tags {
		display: flex;
		gap: 4px;
		flex-wrap: wrap;
	}

	.pill {
		font-size: 11px;
		background: var(--gh-surface);
		border: 1px solid var(--gh-border-muted);
		border-radius: 20px;
		padding: 1px 8px;
		color: var(--gh-text-secondary);
	}

	.post-body {
		border: 1px solid var(--gh-border);
		border-radius: 6px;
		padding: 20px;
		margin-top: 12px;
	}

	.post-body :global(p) {
		font-size: 14px;
		line-height: 1.7;
		color: var(--gh-text-body);
		margin-bottom: 14px;
	}

	.post-body :global(p:last-child) {
		margin-bottom: 0;
	}

	.post-body :global(strong) {
		color: var(--gh-text);
		font-weight: 600;
	}

	.post-body :global(h2) {
		font-size: 16px;
		font-weight: 600;
		color: var(--gh-text);
		margin: 24px 0 12px 0;
		padding-bottom: 8px;
		border-bottom: 1px solid var(--gh-border);
	}

	.post-body :global(h3) {
		font-size: 14px;
		font-weight: 600;
		color: var(--gh-text);
		margin: 20px 0 8px 0;
	}

	.post-body :global(a) {
		color: var(--gh-accent);
		text-decoration: none;
	}

	.post-body :global(a:hover) {
		text-decoration: underline;
	}

	.post-body :global(ul),
	.post-body :global(ol) {
		padding-left: 20px;
		margin: 0 0 14px 0;
	}

	.post-body :global(li) {
		font-size: 14px;
		color: var(--gh-text-body);
		line-height: 1.7;
		margin-bottom: 6px;
	}

	.post-body :global(code) {
		font-size: 13px;
		background: var(--gh-surface);
		padding: 2px 6px;
		border-radius: 6px;
		border: 1px solid var(--gh-border);
	}

	.post-body :global(pre) {
		background: var(--gh-surface);
		border: 1px solid var(--gh-border);
		border-radius: 6px;
		padding: 14px;
		overflow-x: auto;
		margin: 0 0 14px 0;
	}

	.post-body :global(pre code) {
		background: none;
		border: none;
		padding: 0;
	}

	.post-body :global(blockquote) {
		border-left: 3px solid var(--gh-border-muted);
		padding-left: 14px;
		color: var(--gh-text-secondary);
		margin: 0 0 14px 0;
	}

	.post-body :global(img) {
		border-radius: 6px;
		border: 1px solid var(--gh-border);
	}

	.post-body :global(hr) {
		border: none;
		border-top: 1px solid var(--gh-border);
		margin: 24px 0;
	}
</style>
