---
import Page from '../components/Page.astro';
import { getSiteContent } from '../data/siteContent';

const content = getSiteContent('en').errors;
const page = content.notFound;
---

<Page
	title={page.title}
	description={page.description}
	path="/404/"
	layoutVariant="blog-full"
	robots="noindex, nofollow"
	ogImageAlt={page.ogImageAlt}
>
	<section class="error-wrap">
		<p class="code">{page.code}</p>
		<h1>{page.heading}</h1>
		<p class="desc">
			{page.body}
		</p>
		<div class="actions">
			<a href="/" class="btn primary">{content.actions.portfolio}</a>
			<a href="/blog/" class="btn">{content.actions.blog}</a>
		</div>
	</section>
</Page>

<style>
	.error-wrap {
		max-width: 760px;
		margin: 12vh auto 0;
		text-align: center;
		padding: 30px 20px 26px;
	}

	.code {
		font-size: clamp(56px, 13vw, 90px);
		font-weight: 700;
		line-height: 0.95;
		letter-spacing: -0.04em;
		color: var(--text);
		margin-bottom: 8px;
	}

	h1 {
		font-size: clamp(25px, 4.2vw, 34px);
		line-height: 1.2;
		margin-bottom: 10px;
	}

	.desc {
		max-width: 560px;
		margin: 0 auto;
		font-size: 14px;
		line-height: 1.65;
		color: var(--muted);
	}

	.actions {
		margin-top: 20px;
		display: flex;
		gap: 10px;
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		padding: 6px 12px;
		border: 1px solid var(--border-strong);
		border-radius: 6px;
		color: var(--text);
		background: var(--surface);
		font-size: 13px;
	}

	.btn.primary {
		border-color: var(--accent);
		background: color-mix(in srgb, var(--accent) 22%, var(--bg));
		color: var(--accent-hover);
	}

	.btn:hover {
		border-color: var(--accent);
	}

	@media (max-width: 768px) {
		.error-wrap {
			margin-top: 8vh;
			padding: 24px 16px 20px;
		}
	}
</style>
