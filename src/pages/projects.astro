---
import Page from '../components/Page.astro';
import ProjectShowcase from '../components/ProjectShowcase.astro';
import { getLocalizedMobileProjects, getLocalizedWebProjects, getRepositoryProjects, langColors } from '../data/projects';
import { getSiteContent, localizePath, normalizeLocale, siteUrl, type SiteLocale } from '../data/siteContent';

interface Props {
    locale?: SiteLocale;
    path?: string;
}

const locale = normalizeLocale(Astro.props.locale);
const pagePath = Astro.props.path ?? localizePath('/projects/', locale);

const repositories = await getRepositoryProjects({}, locale);
const webProjects = getLocalizedWebProjects(locale);
const mobileProjects = getLocalizedMobileProjects(locale);
const showcaseCount = webProjects.length + mobileProjects.length;
const repositoriesPerPage = 6;
const repositoryPageCount = Math.max(1, Math.ceil(repositories.length / repositoriesPerPage));
const stacks = Array.from(
    new Set([
        ...webProjects.flatMap((project) => project.stack),
        ...mobileProjects.flatMap((project) => project.stack),
        ...repositories.map((project) => project.lang).filter((lang) => lang !== 'Unknown'),
    ])
).slice(0, 18);

const siteContent = getSiteContent(locale);
const content = siteContent.projectsPage;
const breadcrumbJson = JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
        {
            '@type': 'ListItem',
            position: 1,
            name: siteContent.nav.home,
            item: new URL(localizePath('/', locale), siteUrl).toString(),
        },
        {
            '@type': 'ListItem',
            position: 2,
            name: siteContent.nav.projects,
            item: new URL(localizePath('/projects/', locale), siteUrl).toString(),
        },
    ],
});
const projectsCollectionJson = JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: content.seoTitle,
    description: content.seoDescription,
    url: new URL(localizePath('/projects/', locale), siteUrl).toString(),
    mainEntity: {
        '@type': 'ItemList',
        name: content.itemListName,
        numberOfItems: showcaseCount + repositories.length,
        itemListElement: [
            ...webProjects.map((project, index) => ({
                '@type': 'ListItem',
                position: index + 1,
                name: project.name,
                url: project.liveUrl,
            })),
            ...mobileProjects.map((project, index) => ({
                '@type': 'ListItem',
                position: webProjects.length + index + 1,
                name: project.name,
                url: project.repoUrl || new URL(localizePath('/projects/', locale), siteUrl).toString(),
            })),
            ...repositories.map((project, index) => ({
                '@type': 'ListItem',
                position: showcaseCount + index + 1,
                name: project.name,
                url: project.url,
            })),
        ],
    },
});
---

<Page
    title={content.seoTitle}
    description={content.seoDescription}
    path={pagePath}
    locale={locale}
    layoutVariant="portfolio-full"
    ogImageAlt={content.ogImageAlt}
>
    <section class="projects-hero">
        <p class="eyebrow">{content.eyebrow}</p>
        <h1>{content.heading}</h1>
        <p class="hero-copy">
            {content.intro}
        </p>
        <div class="summary-grid" aria-label={content.summary.ariaLabel}>
            <div class="summary-card">
                <span class="summary-value">{webProjects.length}</span>
                <span class="summary-label">{content.summary.webBuilds}</span>
            </div>
            <div class="summary-card">
                <span class="summary-value">{mobileProjects.length}</span>
                <span class="summary-label">{content.summary.mobileApps}</span>
            </div>
            <div class="summary-card">
                <span class="summary-value">{repositories.length}</span>
                <span class="summary-label">{content.summary.repositories}</span>
            </div>
        </div>
    </section>

    <nav class="project-nav" aria-label={content.sectionNavAria}>
        <a href="#showcase">{content.nav.featuredBuilds}</a>
        <a href="#repositories">{content.nav.repositories}</a>
        <a href="#stack">{content.nav.stack}</a>
    </nav>

    <ProjectShowcase heading={content.nav.featuredBuilds} subheading={`${showcaseCount} ${content.featuredSubheading}`} locale={locale} />

    <section id="repositories" class="section">
        <div class="section-heading">
            <h2>{content.nav.repositories}</h2>
            <span class="section-sub">{content.repositoriesSubheading}</span>
            <span class="section-sub repository-page-status" data-page-status>
                {content.pageStatus(1, repositoryPageCount)}
            </span>
        </div>
        <div class="projects-grid">
            {repositories.map((project, index) => {
                const page = Math.floor(index / repositoriesPerPage) + 1;
                return (
                    <a
                        href={project.url}
                        target="_blank"
                        rel="noopener"
                        class="repo-card"
                        data-repo-page={page}
                        hidden={page !== 1}
                    >
                        <div class="repo-header">
                            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="repo-icon"><path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5zm10.5-1h-8a1 1 0 00-1 1v6.708A2.486 2.486 0 014.5 9h8zM5 12.25v3.25a.25.25 0 00.4.2l1.45-1.087a.25.25 0 01.3 0L8.6 15.7a.25.25 0 00.4-.2v-3.25a.25.25 0 00-.25-.25h-3.5a.25.25 0 00-.25.25z"></path></svg>
                            <span class="repo-name">{project.name}</span>
                            <span class="repo-visibility">{content.visibility}</span>
                        </div>
                        <div class="repo-desc">{project.desc}</div>
                        <div class="repo-footer">
                            <span class="repo-lang">
                                <span class="lang-dot" style={`background:${langColors[project.lang] || '#8b949e'}`}></span>
                                {project.lang}
                            </span>
                            {project.stars && (
                                <span class="repo-stars">
                                    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"></path></svg>
                                    {project.stars}
                                </span>
                            )}
                            {project.tags.map((tag) => (
                                <span class="repo-tag">{tag}</span>
                            ))}
                        </div>
                    </a>
                );
            })}
        </div>
        {repositoryPageCount > 1 && (
            <nav
                class="pagination"
                data-repository-pagination
                data-total-pages={repositoryPageCount}
                data-page-status-template={content.pageStatusTemplate}
                aria-label={content.paginationAria}
            >
                <a href="?page=1#repositories" class="pagination-btn" data-page-prev>
                    {content.previous}
                </a>
                <div class="pagination-pages">
                    {Array.from({ length: repositoryPageCount }, (_, index) => {
                        const page = index + 1;
                        return (
                            <a
                                href={`?page=${page}#repositories`}
                                class={page === 1 ? "pagination-page active" : "pagination-page"}
                                data-page-link={page}
                                aria-current={page === 1 ? "page" : undefined}
                            >
                                {page}
                            </a>
                        );
                    })}
                </div>
                <a href="?page=2#repositories" class="pagination-btn" data-page-next>
                    {content.next}
                </a>
            </nav>
        )}
        <div class="explore-link">
            <a href="https://github.com/nabilrn?tab=repositories" target="_blank" rel="noopener">{content.openGithubRepositories}</a>
        </div>
    </section>

    <section id="stack" class="section">
        <div class="section-heading">
            <h2>{content.nav.stack}</h2>
            <span class="section-sub">{content.stackSubheading}</span>
        </div>
        <div class="stack-list">
            {stacks.map((stack) => <span class="pill">{stack}</span>)}
        </div>
    </section>

    <script type="application/ld+json" set:html={breadcrumbJson}></script>
    <script type="application/ld+json" set:html={projectsCollectionJson}></script>
</Page>

<style>
    .projects-hero {
        border: 1px solid var(--gh-border);
        border-radius: 6px;
        padding: 20px;
        background: var(--gh-base);
    }

    .eyebrow {
        font-size: 11px;
        color: var(--gh-text-secondary);
        letter-spacing: 0;
        text-transform: uppercase;
        margin: 0 0 6px 0;
    }

    h1 {
        font-size: 22px;
        line-height: 1.25;
        margin: 0 0 8px 0;
    }

    .hero-copy {
        max-width: 720px;
        margin-bottom: 16px;
        color: var(--gh-text-secondary);
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
    }

    .summary-card {
        border: 1px solid var(--gh-border);
        border-radius: 6px;
        padding: 10px 12px;
        background: var(--gh-surface);
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .summary-value {
        color: var(--gh-text);
        font-size: 18px;
        font-weight: 600;
        line-height: 1;
    }

    .summary-label {
        color: var(--gh-text-secondary);
        font-size: 11px;
    }

    .project-nav {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 12px;
    }

    .project-nav a {
        font-size: 12px;
        color: var(--gh-text-secondary);
        border: 1px solid var(--gh-border-muted);
        border-radius: 20px;
        padding: 4px 10px;
        transition: background-color 0.15s ease, color 0.15s ease;
    }

    .project-nav a:hover {
        background: var(--gh-surface);
        color: var(--gh-text);
    }

    .section {
        padding-top: 24px;
        margin-top: 24px;
        border-top: 1px solid var(--gh-border);
    }

    .section-heading {
        margin-bottom: 12px;
    }

    .section-heading h2 {
        font-size: 13px;
        font-weight: 600;
        color: var(--gh-text);
        margin: 0;
        display: inline;
    }

    .section-sub {
        font-size: 12px;
        color: var(--gh-text-secondary);
        font-weight: 400;
        margin-left: 6px;
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .repo-card {
        background: var(--gh-base);
        border: 1px solid var(--gh-border);
        border-radius: 6px;
        padding: 12px 14px;
        text-decoration: none;
        color: inherit;
        display: block;
        transition: border-color 0.15s ease;
    }

    .repo-card:hover {
        border-color: var(--gh-accent);
    }

    .repo-card[hidden] {
        display: none;
    }

    .repo-card:focus-visible {
        outline: 2px solid var(--gh-accent);
        outline-offset: 2px;
    }

    .repo-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
    }

    .repo-icon {
        opacity: 0.5;
        color: var(--gh-text-secondary);
        flex-shrink: 0;
    }

    .repo-name {
        font-size: 12px;
        font-weight: 600;
        color: var(--gh-accent);
    }

    .repo-visibility {
        font-size: 11px;
        border: 1px solid var(--gh-border-muted);
        border-radius: 20px;
        padding: 0 5px;
        color: var(--gh-text-secondary);
        margin-left: auto;
        line-height: 1.6;
    }

    .repo-desc {
        font-size: 11px;
        color: var(--gh-text-secondary);
        line-height: 1.5;
        margin-bottom: 10px;
    }

    .repo-footer {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .repo-lang,
    .repo-stars {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        color: var(--gh-text-secondary);
    }

    .repo-stars svg {
        opacity: 0.6;
    }

    .lang-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
    }

    .repo-tag,
    .pill {
        font-size: 11px;
        background: var(--gh-surface);
        border: 1px solid var(--gh-border-muted);
        border-radius: 20px;
        padding: 1px 8px;
        color: var(--gh-text-secondary);
        display: inline-block;
    }

    .stack-list {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .repository-page-status {
        display: inline-block;
    }

    .pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-top: 14px;
        padding-top: 14px;
        border-top: 1px solid var(--gh-border);
    }

    .pagination-pages {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .pagination-btn,
    .pagination-page {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 32px;
        min-height: 30px;
        border: 1px solid var(--gh-border-muted);
        border-radius: 6px;
        background: var(--gh-base);
        color: var(--gh-text-secondary);
        font-size: 12px;
        text-decoration: none;
        transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    }

    .pagination-btn {
        padding: 0 10px;
    }

    .pagination-btn:hover,
    .pagination-page:hover,
    .pagination-page.active {
        background: var(--gh-surface);
        border-color: var(--gh-accent);
        color: var(--gh-text);
    }

    .pagination-btn.is-disabled {
        opacity: 0.45;
        pointer-events: none;
    }

    .explore-link {
        margin-top: 12px;
        font-size: 12px;
    }

    .explore-link a {
        color: var(--gh-accent);
        text-decoration: none;
    }

    .explore-link a:hover {
        text-decoration: underline;
    }

    @media (max-width: 768px) {
        .projects-hero {
            padding: 16px;
        }

        h1 {
            font-size: 20px;
        }

        .summary-grid {
            grid-template-columns: 1fr;
        }

        .projects-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .pagination {
            align-items: stretch;
            flex-direction: column;
        }
    }

    @media (max-width: 540px) {
        .projects-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<script is:inline define:vars={{ fallbackPageStatusTemplate: content.pageStatusTemplate }}>
    (() => {
        const pagination = document.querySelector('[data-repository-pagination]');
        if (!pagination) return;

        const cards = Array.from(document.querySelectorAll('[data-repo-page]'));
        const links = Array.from(pagination.querySelectorAll('[data-page-link]'));
        const prev = pagination.querySelector('[data-page-prev]');
        const next = pagination.querySelector('[data-page-next]');
        const status = document.querySelector('[data-page-status]');
        const totalPages = Number(pagination.getAttribute('data-total-pages') || '1');
        const statusTemplate = pagination.getAttribute('data-page-status-template') || fallbackPageStatusTemplate;

        const clampPage = (value) => Math.min(Math.max(value, 1), totalPages);

        const getInitialPage = () => {
            const value = Number(new URL(window.location.href).searchParams.get('page') || '1');
            return Number.isFinite(value) ? clampPage(value) : 1;
        };

        const updateUrl = (page) => {
            const url = new URL(window.location.href);
            if (page === 1) {
                url.searchParams.delete('page');
            } else {
                url.searchParams.set('page', String(page));
            }
            url.hash = 'repositories';
            window.history.replaceState({}, '', url);
        };

        const renderPage = (page, shouldScroll = false) => {
            const current = clampPage(page);

            for (const card of cards) {
                card.hidden = Number(card.getAttribute('data-repo-page')) !== current;
            }

            for (const link of links) {
                const isActive = Number(link.getAttribute('data-page-link')) === current;
                link.classList.toggle('active', isActive);
                if (isActive) {
                    link.setAttribute('aria-current', 'page');
                } else {
                    link.removeAttribute('aria-current');
                }
            }

            if (prev) {
                prev.setAttribute('href', `?page=${Math.max(1, current - 1)}#repositories`);
                prev.classList.toggle('is-disabled', current === 1);
                prev.setAttribute('aria-disabled', String(current === 1));
            }

            if (next) {
                next.setAttribute('href', `?page=${Math.min(totalPages, current + 1)}#repositories`);
                next.classList.toggle('is-disabled', current === totalPages);
                next.setAttribute('aria-disabled', String(current === totalPages));
            }

            if (status) {
                status.textContent = statusTemplate
                    .replace('{current}', String(current))
                    .replace('{total}', String(totalPages));
            }

            updateUrl(current);

            if (shouldScroll) {
                document.getElementById('repositories')?.scrollIntoView({ block: 'start' });
            }
        };

        pagination.addEventListener('click', (event) => {
            const target = event.target.closest('[data-page-link], [data-page-prev], [data-page-next]');
            if (!target || target.getAttribute('aria-disabled') === 'true') return;
            event.preventDefault();

            const href = target.getAttribute('href') || '?page=1';
            const page = Number(new URL(href, window.location.href).searchParams.get('page') || '1');
            renderPage(page, true);
        });

        renderPage(getInitialPage());
    })();
</script>
