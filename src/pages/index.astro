---
import Page from '../components/Page.astro';
---

<Page>
    <!-- About Section -->
    <section id="about">
        <h2>About</h2>
        <p>
            Information Systems undergraduate with strong capabilities in <strong>full-stack</strong> and 
            <strong>cross-platform mobile development</strong> (Android Native, Flutter, KMP). 
            Proficient in <strong>Node.js, Kotlin, React, and Python</strong>.
        </p>
        <p>
            Hands-on experience in <strong>IT infrastructure</strong>, <strong>virtualization (Proxmox)</strong>, 
            <strong>Docker</strong>, and <strong>server resource management</strong>. 
            Passionate about computer systems, virtualization, and networking.
        </p>
    </section>
    
    <hr />
    
    <!-- Experiences Section -->
    <section id="experiences">
        <h2>Experiences</h2>
        
        <div class="experience-item">
            <div class="experience-header">
                <span class="experience-title">Laboratory Assistant - TKITI</span>
                <span class="experience-meta">Coordinator • 2025</span>
            </div>
            <p>Managed and supervised assistant teams to ensure smooth laboratory operations.</p>
            <ul>
                <li>Led discussions on lab module design and curriculum alignment</li>
                <li>Created strategic improvement plans for TKITI Lab development</li>
                <li>Provided training and upgrading materials for new assistants</li>
            </ul>
            <div class="tags">
                <span class="tag">Leadership</span>
                <span class="tag">Curriculum Design</span>
                <span class="tag">Lab Management</span>
            </div>
        </div>
        
        <div class="experience-item">
            <div class="experience-header">
                <span class="experience-title">Bank Nagari (Head Office)</span>
                <span class="experience-meta">Programmer Intern • 2025</span>
            </div>
            <p>Developed an internship management system covering registration, placement, and attendance.</p>
            <ul>
                <li>Built both admin and intern modules in collaboration with one teammate</li>
                <li>Taught Git fundamentals to in-house programmers</li>
                <li>Learned banking IT practices, internal tech stacks, and system concepts</li>
            </ul>
            <div class="tags">
                <span class="tag">Express.js</span>
                <span class="tag">React</span>
                <span class="tag">PostgreSQL</span>
                <span class="tag">Git</span>
            </div>
        </div>
        
        <div class="experience-item">
            <div class="experience-header">
                <span class="experience-title">Laboratory Assistant - Basic Computing</span>
                <span class="experience-meta">Coordinator • 2024 - 2025</span>
            </div>
            <p>Assisted in coordinating assistant tasks and daily lab operations.</p>
            <ul>
                <li>Learned foundational IT infrastructure concepts, including server setup</li>
                <li>Prepared lab environments, materials, and technical setups</li>
            </ul>
            <div class="tags">
                <span class="tag">IT Infrastructure</span>
                <span class="tag">Server Management</span>
            </div>
        </div>
        
        <div class="experience-item">
            <div class="experience-header">
                <span class="experience-title">Bangkit Academy 2024</span>
                <span class="experience-meta">Android Learning Path • 2024</span>
            </div>
            <p>Completed Google's intensive tech training program focused on Android development.</p>
            <ul>
                <li>Learned modern Android development with Kotlin and XML</li>
                <li>Built capstone project Outfyt - Smart OOTD Recommendation App</li>
                <li>Collaborated with 8-person cross-functional team (ML, Cloud, Mobile)</li>
            </ul>
            <div class="tags">
                <span class="tag">Android</span>
                <span class="tag">Kotlin</span>
                <span class="tag">XML</span>
            </div>
        </div>
    </section>
    
    <hr />
    
    <!-- Projects Section -->
    <section id="projects">
        <h2>Projects</h2>
        
        <div class="projects-grid">
            <a href="https://github.com/nabilrn/Momentum" target="_blank" rel="noopener" class="project-card">
                <h3 class="project-title">Momentum</h3>
                <p class="project-desc">Cross-platform habit-tracking app (Android, iOS, Web) with real-time sync and notifications.</p>
                <div class="tags">
                    <span class="tag">Dart</span>
                    <span class="tag">Flutter</span>
                    <span class="tag">Supabase</span>
                </div>
            </a>
            
            <a href="https://github.com/nabilrn/express-api-starter" target="_blank" rel="noopener" class="project-card">
                <h3 class="project-title">Express API Starter</h3>
                <p class="project-desc">A boilerplate for building REST APIs with Express.js and TypeScript. ⭐ 4 stars</p>
                <div class="tags">
                    <span class="tag">TypeScript</span>
                    <span class="tag">Express</span>
                </div>
            </a>
            
            <a href="https://github.com/nabilrn/moviecatalog-kmp" target="_blank" rel="noopener" class="project-card">
                <h3 class="project-title">Movie Catalog KMP</h3>
                <p class="project-desc">Cross-platform movie catalog app built with Kotlin Multiplatform.</p>
                <div class="tags">
                    <span class="tag">Kotlin</span>
                    <span class="tag">KMP</span>
                </div>
            </a>
            
            <a href="https://github.com/nabilrn/Airbnb-BI" target="_blank" rel="noopener" class="project-card">
                <h3 class="project-title">Airbnb BI Dashboard</h3>
                <p class="project-desc">BI dashboard for pricing insights using Kaggle datasets and ML-based recommendations.</p>
                <div class="tags">
                    <span class="tag">TypeScript</span>
                    <span class="tag">Next.js</span>
                </div>
            </a>
            
            <a href="https://github.com/nabilrn/android-firebase-starter" target="_blank" rel="noopener" class="project-card">
                <h3 class="project-title">Android Firebase Starter</h3>
                <p class="project-desc">Android starter template with Firebase integration. ⭐ 2 stars</p>
                <div class="tags">
                    <span class="tag">Kotlin</span>
                    <span class="tag">Firebase</span>
                </div>
            </a>
            
            <a href="https://github.com/nabilrn/Outfyt" target="_blank" rel="noopener" class="project-card">
                <h3 class="project-title">Outfyt</h3>
                <p class="project-desc">Bangkit Capstone - Smart OOTD Recommendation App based on skin tone analysis.</p>
                <div class="tags">
                    <span class="tag">Kotlin</span>
                    <span class="tag">TensorFlow</span>
                </div>
            </a>
            
            <a href="https://github.com/nabilrn/ghibli-gallery" target="_blank" rel="noopener" class="project-card">
                <h3 class="project-title">Ghibli Gallery</h3>
                <p class="project-desc">A beautiful gallery app showcasing Studio Ghibli films.</p>
                <div class="tags">
                    <span class="tag">Kotlin</span>
                    <span class="tag">Android</span>
                </div>
            </a>
            
            <a href="https://github.com/nabilrn/pondok-permai-landingpage" target="_blank" rel="noopener" class="project-card">
                <h3 class="project-title">Pondok Permai Landing Page</h3>
                <p class="project-desc">Responsive landing page showcasing programs, galleries, and community activities.</p>
                <div class="tags">
                    <span class="tag">React</span>
                    <span class="tag">Vite</span>
                </div>
            </a>
        </div>
    </section>
    
    <hr />
    
    <!-- Skills Section -->
    <section id="skills">
        <h2>Skills</h2>
        
        <div class="skills-grid">
            <div class="skill-category">
                <h4>Programming</h4>
                <p>JavaScript, TypeScript, Kotlin, Dart, Python</p>
            </div>
            
            <div class="skill-category">
                <h4>DevOps & Infra</h4>
                <p>Proxmox VE, Docker, Ubuntu Server, GCP, Cloudflare Tunnels</p>
            </div>
            
            <div class="skill-category">
                <h4>Databases</h4>
                <p>MySQL, PostgreSQL, SQLite, Redis</p>
            </div>
            
            <div class="skill-category">
                <h4>Tools</h4>
                <p>Git, VS Code, Android Studio, Figma, Jetbrains</p>
            </div>
        </div>
    </section>
    
    <hr />
    
    <!-- Certifications Section -->
    <section id="certifications">
        <h2>Certifications</h2>
        
        <ul class="cert-list">
            <li>
                <a href="https://dev.id/certificate/verify/41VQQG6VM8" target="_blank" rel="noopener">
                    Dev Certification for Android (DCA) - Dev.id
                </a>
            </li>
            <li>
                <a href="https://www.dicoding.com/certificates/1RXY27E8KXVM" target="_blank" rel="noopener">
                    Android Developer - Dicoding 2024
                </a>
            </li>
        </ul>
    </section>
</Page>