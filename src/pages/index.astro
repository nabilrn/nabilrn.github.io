---
import Page from '../components/Page.astro';
import Terminal from '../components/Terminal.astro';
import { getLocalizedMobileProjects, getLocalizedWebProjects, getRepositoryProjects } from '../data/projects';
import { getSiteContent, localizePath, normalizeLocale, supportedLocales, type SiteLocale } from '../data/siteContent';
import { getCollection } from 'astro:content';
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';
import sharp from 'sharp';

interface Props {
    locale?: SiteLocale;
    path?: string;
}

const locale = normalizeLocale(Astro.props.locale);
const pagePath = Astro.props.path ?? localizePath('/', locale);
const content = getSiteContent(locale);
const home = content.home;

/* Pixel portrait: monochrome, rendered as chunky pixels via CSS */
const pixelPng = await sharp(await readFile(join(process.cwd(), 'src', 'assets', 'profilepict.webp')))
    .resize(96, 96, { fit: 'cover' })
    .grayscale()
    .png({ compressionLevel: 9 })
    .toBuffer();
const pixelPhoto = `data:image/png;base64,${pixelPng.toString('base64')}`;

/* Full name ASCII banner — one line, small block letters */
const nameArtLines = [
    '███╗   ██╗  █████╗  ██████╗  ██╗ ██╗        ██████╗  ██╗ ███████╗ ██╗  ██╗ ██╗   ███╗   ██╗  █████╗  ██╗   ██╗ ██╗ ███████╗  █████╗ ',
    '████╗  ██║ ██╔══██╗ ██╔══██╗ ██║ ██║        ██╔══██╗ ██║ ╚══███╔╝ ██║ ██╔╝ ██║   ████╗  ██║ ██╔══██╗ ██║   ██║ ██║ ██╔════╝ ██╔══██╗',
    '██╔██╗ ██║ ███████║ ██████╔╝ ██║ ██║        ██████╔╝ ██║   ███╔╝  █████╔╝  ██║   ██╔██╗ ██║ ███████║ ██║   ██║ ██║ ███████╗ ███████║',
    '██║╚██╗██║ ██╔══██║ ██╔══██╗ ██║ ██║        ██╔══██╗ ██║  ███╔╝   ██╔═██╗  ██║   ██║╚██╗██║ ██╔══██║ ╚██╗ ██╔╝ ██║ ╚════██║ ██╔══██║',
    '██║ ╚████║ ██║  ██║ ██████╔╝ ██║ ███████╗   ██║  ██║ ██║ ███████╗ ██║  ██╗ ██║   ██║ ╚████║ ██║  ██║  ╚████╔╝  ██║ ███████║ ██║  ██║',
    '╚═╝  ╚═══╝ ╚═╝  ╚═╝ ╚═════╝  ╚═╝ ╚══════╝   ╚═╝  ╚═╝ ╚═╝ ╚══════╝ ╚═╝  ╚═╝ ╚═╝   ╚═╝  ╚═══╝ ╚═╝  ╚═╝   ╚═══╝   ╚═╝ ╚══════╝ ╚═╝  ╚═╝',
];

/* Header block: pixel photo beside the name banner (neofetch layout) */
const headerHtml = [
    '<div class="boot-head">',
    '<div class="boot-photo"><span class="c-dim">+----------------------+</span>',
    `<img class="term-photo" src="${pixelPhoto}" alt="Pixel portrait of ${content.profile.name}">`,
    '<span class="c-dim">+----------------------+</span></div>',
    `<pre class="boot-name">${nameArtLines.join('\n')}</pre>`,
    '</div>',
].join('');

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const preferredPostLocale = locale === 'en' ? 'en' : locale;
const latestPosts = allPosts
    .filter((post) => (post.data.locale ?? 'en') === preferredPostLocale)
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    .slice(0, 3);

const webProjects = getLocalizedWebProjects(locale);
const mobileProjects = getLocalizedMobileProjects(locale);
const repositories = await getRepositoryProjects({}, locale);

const slugify = (name: string) =>
    name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

const projects = [
    ...webProjects.map((p) => ({
        file: `${slugify(p.name)}.txt`,
        lines: [
            p.name,
            '',
            p.desc,
            '',
            `Type:  Web`,
            `Stack: ${p.stack.join(', ')}`,
            `URL:   ${p.liveUrl}`,
            ...(p.repoUrl ? [`Repo:  ${p.repoUrl}`] : []),
        ],
    })),
    ...mobileProjects.map((p) => ({
        file: `${slugify(p.name)}.txt`,
        lines: [
            p.name,
            '',
            p.desc,
            '',
            `Type:  Mobile (${p.platform})`,
            `Stack: ${p.stack.join(', ')}`,
            ...(p.repoUrl ? [`Repo:  ${p.repoUrl}`] : []),
        ],
    })),
    ...repositories.slice(0, 6).map((p) => ({
        file: `${slugify(p.name)}.txt`,
        lines: [
            p.name,
            '',
            p.desc,
            '',
            `Type:  Repository`,
            `Lang:  ${p.lang}${p.stars ? `   Stars: ${p.stars}` : ''}`,
            `URL:   ${p.url}`,
        ],
    })),
];

const postsLines = latestPosts.map((post) => {
    const date = post.data.pubDate.toISOString().slice(0, 10);
    return `${date}  ${post.data.title}`;
});

const files = {
    about: [
        content.profile.name,
        content.profile.role,
        '',
        home.about.body,
    ],
    experience: home.experiences.items.flatMap((item) => [
        item.title,
        `  ${item.period}`,
        ...item.bullets.map((b) => `  - ${b}`),
        `  [${item.tags.join('] [')}]`,
        '',
    ]),
    education: [
        home.education.degree,
        home.education.institution,
        `${home.education.period} — ${home.education.gpa}`,
        '',
        home.education.summary,
    ],
    skills: home.skills.groups.flatMap((group) => [
        `## ${group.label.toLowerCase()}`,
        `  ${[...group.primary, ...group.items].join('  ')}`,
        '',
    ]),
    certifications: home.certifications.items.map((item) => `- ${item.label}\n  ${item.href}`),
    contact: [
        `Email      nabilrizkinavisa@gmail.com`,
        `GitHub     github.com/nabilrn`,
        `LinkedIn   linkedin.com/in/nabilrizkinavisa2004`,
        `X          x.com/NabilrizkiN`,
        `Instagram  instagram.com/nabilrizkinavisa`,
        '',
        `hint: 'open mail' | 'open github' | 'open linkedin'`,
    ],
};

/* overview — everything at once, for visitors who just want to scroll */
const escOv = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const ovHeader = (title: string) =>
    `<span class="c-ph">+-- ${escOv(title.toUpperCase())} ${'-'.repeat(Math.max(2, 36 - title.length))}</span>`;
const ovBlock = (title: string, lines: string[]) => [
    '',
    ovHeader(title),
    '',
    ...lines.map(escOv),
];
const overview = [
    ...ovBlock(home.about.heading, files.about),
    ...ovBlock(home.education.heading, files.education),
    ...ovBlock(home.experiences.heading, files.experience),
    ...ovBlock(home.skills.heading, files.skills),
    ...ovBlock(home.repositories.heading, [
        ...projects.map((p) => p.file),
        '',
        `hint: cat projects/<file> — or 'open projects'`,
    ]),
    ...ovBlock(home.blog.heading, [...postsLines, '', `hint: 'open blog' to read`]),
    ...ovBlock('contact', files.contact),
];

const termData = {
    promptUser: 'visitor@nabilrn',
    files,
    overview,
    headerHtml,
    projects,
    postsLines,
    links: {
        blog: localizePath('/blog/', locale),
        projects: localizePath('/projects/', locale),
        github: 'https://github.com/nabilrn',
        linkedin: 'https://www.linkedin.com/in/nabilrizkinavisa2004',
        x: 'https://x.com/NabilrizkiN',
        instagram: 'https://www.instagram.com/nabilrizkinavisa',
        mail: 'mailto:nabilrizkinavisa@gmail.com',
    },
    langs: Object.fromEntries(supportedLocales.map((l) => [l, localizePath('/', l)])),
    help: [
        'nsh — nabil shell. available commands:',
        '',
        '  overview        print EVERYTHING at once (aliases: info, all)',
        '  help            show this message',
        '  neofetch        system information',
        '  whoami          who is using this terminal',
        '  ls [path]       list files',
        '  cd <dir>        change directory (try: cd projects)',
        '  cat <file>      print file (try: cat about.txt)',
        '  pwd             print working directory',
        '  projects        list all projects',
        '  blog            latest posts',
        '  skills          tech stack',
        '  experience      work history',
        '  education       academic background',
        '  contact         get in touch',
        '  open <target>   open page: blog, projects, github, linkedin, x, instagram, mail',
        '  theme <name>    phosphor: green | amber | white',
        '  lang <code>     switch language: en | id | cn | jp',
        '  history         command history',
        '  date            current date',
        '  echo <text>     print text',
        '  ping            pong',
        '  clear           clear screen (ctrl+l)',
        '  exit            logout (good luck)',
        '',
        'tips: tab = autocomplete, up/down = history, ctrl+c = interrupt',
    ],
    neofetch: [
        `<span class="c-ph"> ███╗   ██╗</span>  <span class="c-key">visitor</span>@<span class="c-key">nabilrn</span>`,
        `<span class="c-ph"> ████╗  ██║</span>  -----------------`,
        `<span class="c-ph"> ██╔██╗ ██║</span>  <span class="c-key">OS</span>: nabilOS web x86_64`,
        `<span class="c-ph"> ██║╚██╗██║</span>  <span class="c-key">Host</span>: portfolio.nabilrn.space`,
        `<span class="c-ph"> ██║ ╚████║</span>  <span class="c-key">Shell</span>: nsh 1.0.0`,
        `<span class="c-ph"> ╚═╝  ╚═══╝</span>  <span class="c-key">Uptime</span>: 21 years`,
        `            <span class="c-key">Locales</span>: en, id, cn, jp`,
        `            <span class="c-key">Stack</span>: TypeScript, React, Node.js, Kotlin, Python`,
        `            <span class="c-key">Infra</span>: Proxmox, Docker, Cloudflare`,
        `            <span class="c-key">CPU</span>: human (1) @ 3.71GHz`,
        `            <span class="c-key">Memory</span>: ${latestPosts.length} posts / ${projects.length} projects indexed`,
        '',
        `<span style="color:#3f3f46">███</span><span style="color:#f87171">███</span><span style="color:#4ade80">███</span><span style="color:#fbbf24">███</span><span style="color:#6ea8fe">███</span><span style="color:#c084fc">███</span><span style="color:#22d3ee">███</span><span style="color:#e4e4e7">███</span>`,
    ],
    boot: [
        'nabilOS web tty1',
        'portfolio login: visitor',
        'Password: ********',
        `Last login: ${new Date().toDateString()} from 127.0.0.1`,
        '',
    ],
    enterHint: 'press ENTER to show information',
    enterSubHint: "(or type 'help' to explore commands)",
};
---

<Page title={home.seoTitle} description={home.seoDescription} path={pagePath} locale={locale} layoutVariant="portfolio-full">
    <h1 style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border-width: 0;">{home.seoTitle}</h1>

    <Terminal termData={termData} />

    <noscript>
        <section>
            <h2>{home.about.heading}</h2>
            <p>{home.about.body}</p>
            <h2>{home.experiences.heading}</h2>
            <ul>
                {home.experiences.items.map((item) => <li>{item.title} — {item.period}</li>)}
            </ul>
            <h2>{home.blog.heading}</h2>
            <ul>
                {latestPosts.map((post) => (
                    <li><a href={localizePath(`/blog/${post.slug}/`, locale)}>{post.data.title}</a></li>
                ))}
            </ul>
            <h2>{home.repositories.heading}</h2>
            <ul>
                {repositories.slice(0, 6).map((p) => <li><a href={p.url}>{p.name}</a> — {p.desc}</li>)}
            </ul>
        </section>
    </noscript>
</Page>

<style>
    noscript section {
        margin-top: 24px;
    }

    noscript h2 {
        font-size: 14px;
        margin: 18px 0 8px;
    }

    noscript li {
        font-size: 13px;
    }
</style>
