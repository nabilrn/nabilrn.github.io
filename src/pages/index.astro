import Page from '../components/Page.astro';
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    .slice(0, 3);

const langColors: Record<string, string> = {
    TypeScript: '#3178c6',
    JavaScript: '#f1e05a',
    Kotlin: '#7F52FF',
    Dart: '#0553b1',
    Python: '#3572A5',
    Go: '#00ADD8',
    React: '#61dafb',
};

interface GitHubRepo {
    name: string;
    description: string | null;
    language: string | null;
    html_url: string;
    stargazers_count: number;
    topics: string[];
}

const GITHUB_USERNAME = 'nabilrn';

// Org repos to include (manually curated, fetched from GitHub API)
const ORG_REPOS = [
    { owner: 'kk-infrastruktur-dan-tata-kelola-dsi', name: 'tkiti.github.io' },
    { owner: 'NeoCentralSI', name: 'Neo-Central-Mobile' },
    { owner: 'NeoCentralSI', name: 'website' },
    { owner: 'NeoCentralSI', name: 'services' },
];

// Fallback data if API fails (name, desc, lang, url, stars, tags)
const FALLBACK_PROJECTS = [
    { name: 'Momentum', desc: 'Cross-platform habit-tracking app with real-time sync and notifications.', lang: 'Dart', url: 'https://github.com/nabilrn/Momentum', tags: ['Flutter', 'Supabase'] },
    { name: 'express-api-starter', desc: 'Boilerplate for building REST APIs with Express.js and TypeScript.', lang: 'TypeScript', url: 'https://github.com/nabilrn/express-api-starter', stars: 4, tags: ['Express'] },
    { name: 'moviecatalog-kmp', desc: 'Cross-platform movie catalog app built with Kotlin Multiplatform.', lang: 'Kotlin', url: 'https://github.com/nabilrn/moviecatalog-kmp', tags: ['KMP'] },
    { name: 'Airbnb-BI', desc: 'BI dashboard for pricing insights using Kaggle datasets and ML recommendations.', lang: 'TypeScript', url: 'https://github.com/nabilrn/Airbnb-BI', tags: ['Next.js'] },
    { name: 'android-firebase-starter', desc: 'Android starter template with Firebase integration.', lang: 'Kotlin', url: 'https://github.com/nabilrn/android-firebase-starter', stars: 2, tags: ['Firebase'] },
    { name: 'Outfyt', desc: 'Bangkit Capstone - Smart OOTD Recommendation App based on skin tone analysis.', lang: 'Kotlin', url: 'https://github.com/nabilrn/Outfyt', tags: ['TensorFlow'] },
];

async function fetchPinnedRepos(): Promise<Array<{ name: string; desc: string; lang: string; url: string; stars?: number; tags: string[] }>> {
    const token = import.meta.env.GITHUB_TOKEN;
    const featuredRepos = (import.meta.env.FEATURED_REPOS as string)?.split(',').map((r: string) => r.trim()).filter(Boolean) || [];

    // If FEATURED_REPOS env var is set, fetch details from GitHub API
    if (featuredRepos.length > 0) {
        try {
            const results = await Promise.allSettled(
                featuredRepos.map(async (repoName: string) => {
                    const res = await fetch(`https://api.github.com/repos/${GITHUB_USERNAME}/${repoName}`, {
                        headers: token ? { 'Authorization': `token ${token}` } : {},
                    });
                    if (!res.ok) throw new Error(`Failed to fetch ${repoName}`);
                    const repo: GitHubRepo = await res.json();
                    return {
                        name: repo.name,
                        desc: repo.description || '',
                        lang: repo.language || 'Unknown',
                        url: repo.html_url,
                        stars: repo.stargazers_count,
                        tags: repo.topics?.slice(0, 2) || [],
                    };
                })
            );
            const successful = results
                .filter((r): r is PromiseFulfilledResult<any> => r.status === 'fulfilled')
                .map((r) => r.value);
            if (successful.length > 0) return successful;
        } catch {
            // Fall through
        }
    }

    // Fetch repos sorted by last commit date (requires token for higher rate limit)
    if (token) {
        try {
            const res = await fetch(
                `https://api.github.com/users/${GITHUB_USERNAME}/repos?sort=pushed&per_page=100&direction=desc&type=owner`,
                {
                    headers: { 'Authorization': `token ${token}` },
                }
            );
            if (res.ok) {
                const allRepos: GitHubRepo[] = await res.json();
                if (Array.isArray(allRepos) && allRepos.length > 0) {
                    // Filter: only repos pushed within the last 7 days
                    const sevenDaysAgo = new Date();
                    sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);

                    const recentRepos = allRepos
                        .filter((repo) => new Date(repo.pushed_at) >= sevenDaysAgo)
                        .slice(0, 6);

                    if (recentRepos.length > 0) {
                        return recentRepos.map((r) => ({
                            name: r.name,
                            desc: r.description || '',
                            lang: r.language || 'Unknown',
                            url: r.html_url,
                            stars: r.stargazers_count,
                            tags: r.topics?.slice(0, 2) || [],
                        }));
                    }
                }
            }
        } catch {
            // Fall through to hardcoded list
        }
    }

    // Fallback: hardcoded list (set FEATURED_REPOS or GITHUB_TOKEN to auto-sync)
    return FALLBACK_PROJECTS;
}

async function fetchOrgRepos(): Promise<Array<{ name: string; desc: string; lang: string; url: string; stars?: number; tags: string[] }>> {
    try {
        const results = await Promise.allSettled(
            ORG_REPOS.map(async ({ owner, name }) => {
                const res = await fetch(`https://api.github.com/repos/${owner}/${name}`);
                if (!res.ok) throw new Error(`Failed to fetch ${name}`);
                const repo: GitHubRepo = await res.json();
                return {
                    name: repo.name,
                    desc: repo.description || '',
                    lang: repo.language || 'Unknown',
                    url: repo.html_url,
                    stars: repo.stargazers_count,
                    tags: repo.topics?.slice(0, 2) || [],
                };
            })
        );
        return results
            .filter((r): r is PromiseFulfilledResult<any> => r.status === 'fulfilled')
            .map((r) => r.value);
    } catch {
        return [];
    }
}

const personalRepos = await fetchPinnedRepos();
const orgReposList = await fetchOrgRepos();
const projects = [...personalRepos, ...orgReposList];
