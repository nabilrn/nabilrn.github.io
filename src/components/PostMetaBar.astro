---
import Icon from './Icon.astro';
interface Props { date: string; readingTime: number; tags: string[] }
const { date, readingTime, tags } = Astro.props;
---
<div class="post-meta-bar">
  <div class="meta-left">
    <span class="author">By <strong>Nabil Rizki Navisa</strong></span>
    <span class="dot">•</span>
    <span class="date">{date}</span>
    <span class="dot">•</span>
    <span class="reading"><Icon name="clock" /> {readingTime} min</span>
  </div>
  <div class="meta-right">
    <div class="tag-list">
      {tags.map(t => <span class="tag">{t}</span>)}
    </div>
  </div>
</div>

<style>
.post-meta-bar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:1rem;
  margin:0.25rem 0 1rem 0;
  color:var(--sl-color-gray-2);
}
.post-meta-bar .meta-left{display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap}
.post-meta-bar .dot{color:var(--sl-color-gray-4)}
.post-meta-bar .reading{display:inline-flex;align-items:center;gap:0.35rem;color:var(--sl-color-gray-3)}
.post-meta-bar .tag-list{display:flex;gap:0.35rem;flex-wrap:wrap}
.post-meta-bar .tag{background:var(--sl-color-gray-6);padding:0.25rem 0.5rem;border-radius:6px;font-size:0.8rem;color:var(--sl-color-gray-2);border:1px solid var(--sl-color-gray-5)}
</style>
