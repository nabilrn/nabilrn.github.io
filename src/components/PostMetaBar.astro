---
import Icon from './Icon.astro';
interface Props { date: string; readingTime: number; tags: string[] }
const { date, readingTime, tags } = Astro.props;
---
<div class="post-meta-bar">
  <div class="meta-left">
    <span class="author">By <strong>Nabil Rizki Navisa</strong></span>
    <span class="dot">/</span>
    <span class="date">{date}</span>
    <span class="dot">/</span>
    <span class="reading"><Icon name="clock" /> {readingTime} min</span>
  </div>
  <div class="meta-right">
    <div class="tag-list">
      {tags.map(t => <span class="pill">{t}</span>)}
    </div>
  </div>
</div>

<style>
.post-meta-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin: 4px 0 12px 0;
  font-size: 12px;
  color: var(--gh-text-secondary);
}

.meta-left {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}

.meta-left strong {
  color: var(--gh-text);
  font-weight: 600;
}

.dot {
  color: var(--gh-border-muted);
}

.reading {
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

.tag-list {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
}

.pill {
  font-size: 11px;
  background: var(--gh-surface);
  border: 1px solid var(--gh-border-muted);
  border-radius: 20px;
  padding: 1px 8px;
  color: var(--gh-text-secondary);
}
</style>
