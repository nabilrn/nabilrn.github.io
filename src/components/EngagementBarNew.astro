---
import Icon from './Icon.astro';

interface Props {
	postId: string;
	title: string;
	variant?: 'inline' | 'floating';
}

const { postId, title, variant = 'inline' } = Astro.props;
const apiBase = import.meta.env.PUBLIC_ENGAGEMENT_API_BASE ?? '';
const rootId = `engage-${postId}`;
---

<div id={rootId} class={`engage ${variant === 'floating' ? 'floating' : 'inline'}`} data-post-id={postId} data-api-base={apiBase} data-title={title} aria-live="polite">
	<div class="engage-stats">
		<span class="engage-stat"><Icon name="views" /> <strong data-views>0</strong></span>
		<span class="engage-stat"><Icon name="heart" /> <strong data-likes>0</strong></span>
		<span class="engage-stat"><Icon name="share" /> <strong data-shares>0</strong></span>
	</div>
	<div class="engage-actions">
		<button class="engage-btn" aria-label="Like post" data-like-btn><Icon name="heart" /> <span class="label">Like</span></button>
		<button class="engage-btn" data-share-btn="copy" aria-label="Copy link"><Icon name="copy" /> <span class="label">Copy</span></button>
	</div>
</div>
<div id={`${rootId}-toast`} aria-hidden="true" class="toast"></div>

<style>
	.engage {
		border: 1px solid var(--gh-border);
		border-radius: 10px;
		padding: 10px 14px;
		background: var(--gh-surface);
		display: flex;
		align-items: center;
		gap: 14px;
	}

	.engage-stats {
		display: flex;
		gap: 14px;
		align-items: center;
	}

	.engage-stat {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-size: 12px;
		color: var(--gh-text-secondary);
	}

	.engage-stat strong {
		color: var(--gh-text);
		font-weight: 600;
	}

	.engage-actions {
		display: flex;
		gap: 6px;
		margin-left: auto;
	}

	.engage-btn {
		display: flex;
		align-items: center;
		gap: 5px;
		font-size: 12px;
		color: var(--gh-text-secondary);
		padding: 5px 10px;
		border-radius: 8px;
		border: 1px solid transparent;
		background: transparent;
		cursor: pointer;
		font-family: inherit;
		transition: background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
	}

	.engage-btn:hover {
		border-color: var(--gh-border-muted);
		background: var(--gh-surface-2);
	}

	.engage-btn.liked {
		color: var(--gh-red);
	}

	.engage.floating {
		position: sticky;
		top: 84px;
		width: 84px;
		padding: 8px;
		flex-direction: column;
		align-items: stretch;
		gap: 8px;
		border-radius: 12px;
	}

	.engage.floating .engage-stats {
		flex-direction: column;
		align-items: stretch;
		gap: 6px;
	}

	.engage.floating .engage-stat {
		background: var(--gh-base);
		border: 1px solid var(--gh-border);
		border-radius: 8px;
		padding: 5px 6px;
		justify-content: space-between;
		font-size: 11px;
	}

	.engage.floating .engage-actions {
		margin-left: 0;
		flex-direction: column;
		gap: 6px;
	}

	.engage.floating .engage-btn {
		width: 100%;
		justify-content: center;
		padding: 7px 6px;
	}

	.engage.floating .engage-btn .label {
		display: none;
	}

	@media (max-width: 1080px) {
		.engage.floating {
			position: fixed;
			left: 12px;
			right: 12px;
			bottom: calc(12px + env(safe-area-inset-bottom));
			top: auto;
			width: auto;
			z-index: 40;
			flex-direction: row;
			align-items: center;
			padding: 8px 12px;
			gap: 10px;
			border-radius: 999px;
			box-shadow: 0 8px 22px rgba(1, 4, 9, 0.38);
		}

		.engage.floating .engage-stats {
			flex-direction: row;
			align-items: center;
			gap: 10px;
		}

		.engage.floating .engage-stat {
			border: none;
			background: transparent;
			padding: 0;
			font-size: 12px;
			gap: 4px;
		}

		.engage.floating .engage-actions {
			flex-direction: row;
			margin-left: auto;
		}

		.engage.floating .engage-btn {
			padding: 8px;
			border-radius: 999px;
			background: var(--gh-base);
			border-color: var(--gh-border-muted);
		}
	}
</style>

<script is:inline define:vars={{ rootId }}>
	const root = document.getElementById(rootId);
	(function () {
		const el = root;
		if (!el) return;
		const pid = el.dataset.postId;
		const api = el.dataset.apiBase || '';
		const viewsEl = el.querySelector('[data-views]');
		const likesEl = el.querySelector('[data-likes]');
		const sharesEl = el.querySelector('[data-shares]');
		const likeBtn = el.querySelector('[data-like-btn]');
		const shareBtns = el.querySelectorAll('[data-share-btn]');
		const toastId = `${rootId}-toast`;
		const visitorKey = 'portfolio:visitor-id';

		function getVisitor() {
			let visitor = localStorage.getItem(visitorKey);
			if (visitor) return visitor;
			visitor = crypto.randomUUID();
			localStorage.setItem(visitorKey, visitor);
			return visitor;
		}

		const visitor = getVisitor();

		async function fetchApi(body) {
			const endpoint = api.replace(/\/$/, '') + '/metrics/' + encodeURIComponent(pid);
			const res = body
				? await fetch(endpoint, {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify(body),
				  })
				: await fetch(endpoint);
			if (!res.ok) throw new Error('bad');
			return await res.json();
		}

		function setCounts(metrics) {
			if (viewsEl) viewsEl.textContent = metrics.views;
			if (likesEl) likesEl.textContent = metrics.likes;
			if (sharesEl) sharesEl.textContent = metrics.shares;
		}

		function showToast(msg) {
			let toast = document.getElementById(toastId);
			if (!toast) {
				toast = document.createElement('div');
				toast.id = toastId;
				document.body.appendChild(toast);
			}
			toast.textContent = msg;
			toast.style.position = 'fixed';
			toast.style.right = '1rem';
			toast.style.bottom = '1.25rem';
			toast.style.background = 'var(--gh-surface-2)';
			toast.style.color = 'var(--gh-text)';
			toast.style.padding = '6px 12px';
			toast.style.borderRadius = '6px';
			toast.style.border = '1px solid var(--gh-border-muted)';
			toast.style.fontSize = '12px';
			toast.style.opacity = '1';
			toast.style.transition = 'opacity 0.15s ease';
			setTimeout(() => {
				try {
					toast.style.opacity = '0';
				} catch {}
			}, 2000);
		}

		(async () => {
			try {
				if (api) {
					const metrics = await fetchApi();
					setCounts(metrics);
					if (metrics.liked) likeBtn?.classList.add('liked');
				}
			} catch {}

			try {
				if (api) {
					const metrics = await fetchApi({ action: 'view', visitorId: visitor });
					setCounts(metrics);
				}
			} catch {}

			if (!api) {
				const key = 'portfolio:views:' + pid;
				let views = Number(localStorage.getItem(key) || '0');
				const seenKey = 'portfolio:viewed-once:' + pid;
				if (!localStorage.getItem(seenKey)) {
					views++;
					localStorage.setItem(key, String(views));
					localStorage.setItem(seenKey, '1');
				}
				if (viewsEl) viewsEl.textContent = String(views);
			}
		})();

		likeBtn?.addEventListener('click', async () => {
			try {
				if (api) {
					const metrics = await fetchApi({ action: 'like', visitorId: visitor });
					setCounts(metrics);
					const active = !!metrics.liked;
					likeBtn.classList.toggle('liked', active);
					return;
				}
			} catch {}

			const likesKey = 'portfolio:likes:' + pid;
			const likedKey = 'portfolio:liked:' + pid;
			let count = Number(localStorage.getItem(likesKey) || '0');
			let liked = localStorage.getItem(likedKey) === '1';
			liked = !liked;
			count = liked ? count + 1 : Math.max(0, count - 1);
			localStorage.setItem(likesKey, String(count));
			localStorage.setItem(likedKey, liked ? '1' : '0');
			if (likesEl) likesEl.textContent = String(count);
			likeBtn.classList.toggle('liked', liked);
		});

		shareBtns.forEach((button) =>
			button.addEventListener('click', async () => {
				const mode = button.dataset.shareBtn;
				const url = window.location.href;
				try {
					if (mode === 'copy') {
						await navigator.clipboard.writeText(url);
						showToast('Link copied');
					}
					if (api) {
						await fetchApi({ action: 'share' });
						const metrics = await fetchApi();
						setCounts(metrics);
						return;
					}
				} catch {
					showToast('Copied');
				}
				const sharesKey = 'portfolio:shares:' + pid;
				let count = Number(localStorage.getItem(sharesKey) || '0');
				count++;
				localStorage.setItem(sharesKey, String(count));
				if (sharesEl) sharesEl.textContent = String(count);
			})
		);
	})();
</script>
