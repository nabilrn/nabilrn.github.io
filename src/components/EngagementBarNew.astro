---
import Icon from './Icon.astro';
interface Props { postId: string; title: string }
const { postId, title } = Astro.props;
const apiBase = import.meta.env.PUBLIC_ENGAGEMENT_API_BASE ?? '';
---
<div class="engage" data-post-id={postId} data-api-base={apiBase} data-title={title} aria-live="polite">
  <div class="engage-stats">
    <span class="engage-stat"><Icon name="views" /> <strong data-views>0</strong></span>
    <span class="engage-stat"><Icon name="heart" /> <strong data-likes>0</strong></span>
    <span class="engage-stat"><Icon name="share" /> <strong data-shares>0</strong></span>
  </div>
  <div class="engage-actions">
    <button class="engage-btn" aria-label="Like post" data-like-btn><Icon name="heart" /> Like</button>
    <button class="engage-btn" data-share-btn="copy" aria-label="Copy link"><Icon name="copy" /> Copy</button>
  </div>
</div>
<div id="toast-copied" aria-hidden="true" class="toast"></div>

<style>
.engage {
  border: 1px solid var(--gh-border);
  border-radius: 6px;
  padding: 10px 16px;
  background: var(--gh-surface);
  display: flex;
  align-items: center;
  gap: 16px;
}

.engage-stats {
  display: flex;
  gap: 16px;
  align-items: center;
}

.engage-stat {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  color: var(--gh-text-secondary);
}

.engage-stat strong {
  color: var(--gh-text);
  font-weight: 600;
}

.engage-actions {
  display: flex;
  gap: 6px;
  margin-left: auto;
}

.engage-btn {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  color: var(--gh-text-secondary);
  padding: 4px 8px;
  border-radius: 6px;
  border: 1px solid transparent;
  background: transparent;
  cursor: pointer;
  font-family: inherit;
  transition: background-color 0.15s ease, border-color 0.15s ease;
}

.engage-btn:hover {
  border-color: var(--gh-border-muted);
  background: var(--gh-surface-2);
}

.engage-btn.liked {
  color: var(--gh-red);
}
</style>

<script>
const root = document.currentScript?.parentElement ?? document.querySelector('.engage');
(function(){
  const el = root;
  if(!el) return;
  const pid = el.dataset.postId;
  const api = el.dataset.apiBase || '';
  const viewsEl = el.querySelector('[data-views]');
  const likesEl = el.querySelector('[data-likes]');
  const sharesEl = el.querySelector('[data-shares]');
  const likeBtn = el.querySelector('[data-like-btn]');
  const shareBtns = el.querySelectorAll('[data-share-btn]');
  const visitorKey = 'portfolio:visitor-id';
  function getVisitor(){let v=localStorage.getItem(visitorKey);if(v) return v; v=crypto.randomUUID();localStorage.setItem(visitorKey,v);return v}
  const visitor = getVisitor();
  async function fetchApi(body){
    const endpoint = api.replace(/\/$/, '') + '/metrics/' + encodeURIComponent(pid);
    const res = body ? await fetch(endpoint,{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(body)}) : await fetch(endpoint);
    if(!res.ok) throw new Error('bad');
    return await res.json();
  }
  function setCounts(m){ if(viewsEl) viewsEl.textContent = m.views; if(likesEl) likesEl.textContent = m.likes; if(sharesEl) sharesEl.textContent = m.shares }
  function showToast(msg){ let toast = document.getElementById('toast-copied'); if(!toast){ toast = document.createElement('div'); toast.id='toast-copied'; toast.className='toast'; document.body.appendChild(toast);} toast.textContent = msg;
    toast.style.position = 'fixed'; toast.style.right = '1rem'; toast.style.bottom = '1.25rem'; toast.style.background = 'var(--gh-surface-2)'; toast.style.color = 'var(--gh-text)'; toast.style.padding = '6px 12px'; toast.style.borderRadius = '6px'; toast.style.border = '1px solid var(--gh-border-muted)'; toast.style.fontSize = '12px'; toast.style.opacity = '1'; toast.style.transition = 'opacity 0.15s ease'; setTimeout(()=>{ try{ toast.style.opacity='0'; }catch(e){} },2000);
  }
  (async()=>{
    try{ if(api){ const m = await fetchApi(); setCounts(m);
        if(m.liked){ likeBtn?.classList.add('liked'); }
      } }catch{}
    try{ if(api){ const m = await fetchApi({action:'view',visitorId:visitor}); setCounts(m); } }catch{}
    if(!api){ const k='portfolio:views:'+pid; let v=Number(localStorage.getItem(k)||'0'); const seenKey='portfolio:viewed-once:'+pid; if(!localStorage.getItem(seenKey)){ v++; localStorage.setItem(k,String(v)); localStorage.setItem(seenKey,'1'); } if(viewsEl) viewsEl.textContent = String(v);}
  })();
  likeBtn?.addEventListener('click',async()=>{
    try{
      if(api){ const m = await fetchApi({action:'like',visitorId:visitor}); setCounts(m); const active = !!m.liked; likeBtn.classList.toggle('liked', active);
        return
      }
    }catch{}
    const lk='portfolio:likes:'+pid; const likedKey='portfolio:liked:'+pid; let count=Number(localStorage.getItem(lk)||'0'); let liked = localStorage.getItem(likedKey) === '1'; liked = !liked; if(liked){ count++; } else { count = Math.max(0,count-1)} localStorage.setItem(lk,String(count)); localStorage.setItem(likedKey, liked ? '1' : '0'); if(likesEl) likesEl.textContent = String(count); likeBtn.classList.toggle('liked', liked);
  });
  shareBtns.forEach(b=>b.addEventListener('click',async(e)=>{
    const mode = b.dataset.shareBtn;
    const url = window.location.href;
    try{
      if(mode==='copy'){
        await navigator.clipboard.writeText(url);
        showToast('Link copied');
      }
      if(api){ await fetchApi({action:'share'}); const m= await fetchApi(); setCounts(m); return }
    }catch{
      showToast('Copied');
    }
    const sk='portfolio:shares:'+pid; let c=Number(localStorage.getItem(sk)||'0'); c++; localStorage.setItem(sk,String(c)); if(sharesEl) sharesEl.textContent = String(c);
  }));
})();
</script>
