---
import PortfolioLayout from './PortfolioLayout.astro';
import BlogLayout from './BlogLayout.astro';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  lang?: 'en' | 'id';
  robots?: string;
  layoutVariant?: 'portfolio' | 'blog-full';
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  twitterCard?: 'summary' | 'summary_large_image';
  publishedTime?: string;
  modifiedTime?: string;
  articleTags?: string[];
  ogImageWidth?: number;
  ogImageHeight?: number;
}

const {
  title: pageTitle,
  description: pageDesc,
  path,
  lang = 'en',
  robots = 'index, follow',
  layoutVariant = 'portfolio',
  ogImage: pageOgImage,
  ogImageAlt,
  ogType = 'website',
  twitterCard = 'summary_large_image',
  publishedTime,
  modifiedTime,
  articleTags = [],
  ogImageWidth,
  ogImageHeight,
} = Astro.props;

const siteUrl = 'https://nabilrizkinavisa.me';
const defaultTitle = 'Nabil Rizki Navisa | Software Engineer';
const defaultDescription = 'Portfolio of Nabil Rizki Navisa - Software Engineer, AI Agent Enthusiast, and IT Infrastructure Enthusiast. Proficient in Node.js, Kotlin, React, Flutter, and Python. Based in Indonesia.';
const defaultOgImage = '/og/default-og.png';

const title = pageTitle || defaultTitle;
const description = pageDesc || defaultDescription;
const currentUrl = path ? new URL(path, siteUrl).toString() : siteUrl;
const ogImageUrl = new URL(pageOgImage ?? defaultOgImage, siteUrl).toString();
const ogLocale = lang === 'id' ? 'id_ID' : 'en_US';
---

<!doctype html>
<html lang={lang}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Nabil Rizki Navisa" />
    <meta name="keywords" content="Nabil Rizki Navisa, Nabil Navisa, Nabil Rizki, nabilrn, nabilrizkinavisa, Software Engineer, AI Agent Enthusiast, IT Infrastructure Enthusiast, Backend Developer, Frontend Developer, Android Developer, Mobile Developer, Kotlin Developer, Flutter Developer, React Developer, Node.js Developer, TypeScript Developer, Python Developer, IT Infrastructure, DevOps, Proxmox, Docker, GCP, Web Developer, Indonesia, Padang, Universitas Andalas, UNAND, Information Systems, Bangkit Academy, Portfolio, Programmer, Tech Enthusiast" />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={currentUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    {ogImageWidth && <meta property="og:image:width" content={String(ogImageWidth)} />}
    {ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}
    <meta property="og:site_name" content="Nabil Rizki Navisa" />
    <meta property="og:locale" content={ogLocale} />
    {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {ogType === 'article' &&
      articleTags.length > 0 &&
      articleTags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}

    <!-- Twitter -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:url" content={currentUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.svg" />
    <meta name="theme-color" content="#0d1117" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" is:inline>
    {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Nabil Rizki Navisa",
        "alternateName": ["Nabil Navisa", "Nabil Rizki", "nabilrn", "nabilrizkinavisa"],
        "url": "https://nabilrizkinavisa.me",
        "email": "nabilrizkinavisa@gmail.com",
        "jobTitle": "Software Engineer",
        "description": "Software Engineer, AI Agent Enthusiast, and IT Infrastructure Enthusiast based in Indonesia. Specializing in web development, mobile development, and DevOps.",
        "sameAs": [
            "https://github.com/nabilrn",
            "https://www.linkedin.com/in/nabilrizkinavisa2004",
            "https://www.instagram.com/nabilrizkinavisa"
        ],
        "alumniOf": {
            "@type": "CollegeOrUniversity",
            "name": "Universitas Andalas",
            "alternateName": "UNAND"
        },
        "knowsAbout": ["Software Engineering", "AI Agents", "JavaScript", "TypeScript", "Kotlin", "Dart", "Flutter", "React", "Node.js", "Express.js", "Next.js", "Android Development", "Mobile Development", "DevOps", "Docker", "Proxmox", "PostgreSQL", "Redis", "Python", "IT Infrastructure"],
        "worksFor": {
            "@type": "Organization",
            "name": "Freelance / Open for Opportunities"
        },
        "nationality": {
            "@type": "Country",
            "name": "Indonesia"
        }
    }
    </script>
    <script type="application/ld+json" is:inline>
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Nabil Rizki Navisa",
        "url": "https://nabilrizkinavisa.me",
        "potentialAction": {
            "@type": "SearchAction",
            "target": {
                "@type": "EntryPoint",
                "urlTemplate": "https://nabilrizkinavisa.me/blog/?q={search_term_string}"
            },
            "query-input": "required name=search_term_string"
        }
    }
    </script>
</head>
<body>
    {layoutVariant === 'blog-full' ? (
        <BlogLayout>
            <slot />
        </BlogLayout>
    ) : (
        <PortfolioLayout>
            <slot />
        </PortfolioLayout>
    )}
</body>
</html>

<style is:global>
    *,
    *::before,
    *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    :root {
        --gh-base: #0d1117;
        --gh-surface: #161b22;
        --gh-surface-2: #21262d;
        --gh-border: #21262d;
        --gh-border-muted: #30363d;
        --gh-text: #e6edf3;
        --gh-text-secondary: #8b949e;
        --gh-text-body: #c9d1d9;
        --gh-accent: #388bfd;
        --gh-accent-hover: #58a6ff;
        --gh-green: #3fb950;
        --gh-green-bg: rgba(35,134,54,0.15);
        --gh-green-border: rgba(35,134,54,0.4);
        --gh-red: #f78166;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
        font-size: 13px;
        line-height: 1.5;
        background: var(--gh-base);
        color: var(--gh-text);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    a {
        color: inherit;
        text-decoration: none;
    }

    h1, h2, h3, h4, h5, h6 {
        font-weight: 600;
        color: var(--gh-text);
    }

    p {
        font-size: 14px;
        line-height: 1.7;
        color: var(--gh-text-body);
        margin: 0 0 14px 0;
    }

    strong {
        color: var(--gh-text);
        font-weight: 600;
    }

    ul, ol {
        padding-left: 20px;
        margin: 0 0 14px 0;
    }

    li {
        font-size: 12px;
        color: var(--gh-text-body);
        line-height: 1.5;
        margin: 0 0 6px 0;
    }

    li::marker {
        color: var(--gh-text-secondary);
    }

    hr {
        border: none;
        border-top: 1px solid var(--gh-border);
        margin: 24px 0;
    }

    img {
        max-width: 100%;
    }
</style>
