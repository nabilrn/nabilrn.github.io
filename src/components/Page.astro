---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import PortfolioLayout from './PortfolioLayout.astro';
import PortfolioFullLayout from './PortfolioFullLayout.astro';
import {
  authorName,
  getSiteContent,
  localeMeta,
  localizePath,
  normalizeLocale,
  siteUrl,
  stripLocaleFromPath,
  supportedLocales,
  type SiteLocale,
} from '../data/siteContent';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  locale?: SiteLocale;
  lang?: string;
  robots?: string;
  layoutVariant?: 'portfolio' | 'portfolio-full' | 'blog-full';
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  twitterCard?: 'summary' | 'summary_large_image';
  publishedTime?: string;
  modifiedTime?: string;
  articleTags?: string[];
  ogImageWidth?: number;
  ogImageHeight?: number;
  alternatePaths?: Partial<Record<SiteLocale, string>>;
}

const {
  title: pageTitle,
  description: pageDesc,
  path,
  locale: pageLocale,
  lang = 'en',
  robots = 'index, follow',
  layoutVariant = 'portfolio',
  ogImage: pageOgImage,
  ogImageAlt,
  ogType = 'website',
  twitterCard = 'summary_large_image',
  publishedTime,
  modifiedTime,
  articleTags = [],
  ogImageWidth,
  ogImageHeight,
  alternatePaths,
} = Astro.props;

const contentLocale = normalizeLocale(pageLocale ?? lang);
const content = getSiteContent(contentLocale);
const defaultTitle = content.seo.defaultTitle;
const defaultDescription = content.seo.defaultDescription;
const defaultOgImage = '/og/default-og.png';

const title = pageTitle || defaultTitle;
const description = pageDesc || defaultDescription;
const currentUrl = path ? new URL(path, siteUrl).toString() : siteUrl;
const unlocalizedPath = stripLocaleFromPath(path ?? '/');
const isHomePageForSchema = unlocalizedPath === '/';
const htmlLang = localeMeta[contentLocale].htmlLang;
const ogImageUrl = new URL(pageOgImage ?? defaultOgImage, siteUrl).toString();
const ogLocale = localeMeta[contentLocale].ogLocale;
const alternateUrls = supportedLocales.map((localeOption) => ({
  hreflang: localeMeta[localeOption].htmlLang,
  href: new URL(alternatePaths?.[localeOption] ?? localizePath(unlocalizedPath, localeOption), siteUrl).toString(),
}));
const alternateOgLocales = supportedLocales
  .filter((localeOption) => localeOption !== contentLocale)
  .map((localeOption) => localeMeta[localeOption].ogLocale);
const xDefaultPath = alternatePaths?.en ?? unlocalizedPath;
const personEntity = {
  '@type': 'Person',
  '@id': `${siteUrl}/#person`,
  name: authorName,
  alternateName: content.schema.alternateName,
  url: siteUrl,
  email: content.schema.email,
  jobTitle: content.schema.jobTitle,
  description: content.schema.personDescription,
  sameAs: content.schema.sameAs,
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: content.schema.alumniName,
    alternateName: content.schema.alumniAlternateName,
  },
  hasCredential: {
    '@type': 'EducationalOccupationalCredential',
    name: content.schema.degreeName,
    description: `${content.schema.degreeName}, ${content.schema.graduationDate}, GPA ${content.schema.gpa}`,
    credentialCategory: content.schema.credentialCategory,
    educationalLevel: content.schema.educationalLevel,
    recognizedBy: {
      '@type': 'CollegeOrUniversity',
      name: content.schema.alumniName,
      alternateName: content.schema.alumniAlternateName,
    },
  },
  award: `GPA ${content.schema.gpa}`,
  knowsAbout: content.schema.knowsAbout,
  worksFor: {
    '@type': 'Organization',
    name: content.schema.worksFor,
  },
  nationality: {
    '@type': 'Country',
    name: content.schema.nationality,
  },
} as const;
const personJson = JSON.stringify({
  '@context': 'https://schema.org',
  ...personEntity,
});
const websiteJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  name: authorName,
  alternateName: content.seo.siteAlternateName,
  url: siteUrl,
  inLanguage: htmlLang,
  publisher: {
    '@id': `${siteUrl}/#person`,
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteUrl}${localizePath('/blog/', contentLocale)}?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
});
const webPageJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': isHomePageForSchema ? 'ProfilePage' : 'WebPage',
  '@id': `${currentUrl}#webpage`,
  url: currentUrl,
  name: title,
  description,
  inLanguage: htmlLang,
  isPartOf: {
    '@id': `${siteUrl}/#website`,
  },
  author: {
    '@id': `${siteUrl}/#person`,
  },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: ogImageUrl,
    ...(ogImageWidth ? { width: ogImageWidth } : {}),
    ...(ogImageHeight ? { height: ogImageHeight } : {}),
  },
  ...(isHomePageForSchema ? { mainEntity: { '@id': `${siteUrl}/#person` } } : {}),
});
const siteNavigationJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Primary site navigation',
  itemListElement: [
    {
      '@type': 'SiteNavigationElement',
      position: 1,
      name: content.nav.overview,
      url: new URL(localizePath('/', contentLocale), siteUrl).toString(),
    },
    {
      '@type': 'SiteNavigationElement',
      position: 2,
      name: content.nav.projects,
      url: new URL(localizePath('/projects/', contentLocale), siteUrl).toString(),
    },
    {
      '@type': 'SiteNavigationElement',
      position: 3,
      name: content.nav.blog,
      url: new URL(localizePath('/blog/', contentLocale), siteUrl).toString(),
    },
  ],
});
---

<!doctype html>
<html lang={htmlLang} data-theme="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('starlight-theme');
          const theme = stored === 'light' || stored === 'dark' ? stored : 'dark';
          document.documentElement.dataset.theme = theme;
        } catch {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={authorName} />
    <meta name="application-name" content={authorName} />
    <meta name="color-scheme" content="dark light" />
    <meta name="keywords" content={content.seo.keywords} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={currentUrl} />
    <link rel="home" href={siteUrl} />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    {alternateUrls.map((item) => <link rel="alternate" hreflang={item.hreflang} href={item.href} />)}
    <link rel="alternate" hreflang="x-default" href={new URL(xDefaultPath, siteUrl).toString()} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    {ogImageWidth && <meta property="og:image:width" content={String(ogImageWidth)} />}
    {ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}
    <meta property="og:site_name" content={content.seo.ogSiteName} />
    <meta property="og:locale" content={ogLocale} />
    {alternateOgLocales.map((alternateLocale) => <meta property="og:locale:alternate" content={alternateLocale} />)}
    {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {ogType === 'article' &&
      articleTags.length > 0 &&
      articleTags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}

    <!-- Twitter -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:url" content={currentUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:creator" content="@NabilrizkiN" />
    {ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.svg" />
    <meta name="theme-color" content={content.seo.themeColor} media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={personJson}></script>
    {isHomePageForSchema && <script type="application/ld+json" set:html={websiteJson}></script>}
    <script type="application/ld+json" set:html={webPageJson}></script>
    <script type="application/ld+json" set:html={siteNavigationJson}></script>
</head>
<body>
    {layoutVariant === 'portfolio-full' || layoutVariant === 'blog-full' ? (
        <PortfolioFullLayout currentPath={path} locale={contentLocale} alternatePaths={alternatePaths}>
            <slot />
        </PortfolioFullLayout>
    ) : (
        <PortfolioLayout currentPath={path} locale={contentLocale}>
            <slot />
        </PortfolioLayout>
    )}
</body>
</html>

<style is:global>
    *,
    *::before,
    *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    :root,
    html[data-theme='dark'] {
        color-scheme: dark;
        --bg: #0a0a0a;
        --surface: #111111;
        --surface-2: #181818;
        --border: #1f1f1f;
        --border-strong: #2e2e2e;
        --text: #e8e8e8;
        --muted: #8a8a8a;
        --text-body: #b8b8b8;
        --accent: #f0f0f0;
        --accent-hover: #ffffff;
        --hint: #d4d4d4;
        --dir: #b8b8b8;
        --ok: #d4d4d4;
        --ok-bg: rgba(255, 255, 255, 0.06);
        --ok-border: rgba(255, 255, 255, 0.18);
        --warn: #fbbf24;
        --danger: #f87171;
        --done: #d4d4d4;
        --shadow: 0 18px 44px rgba(0, 0, 0, 0.55);
        --contrib-0: #161616;
        --contrib-1: #2a2a2a;
        --contrib-2: #484848;
        --contrib-3: #787878;
        --contrib-4: #c0c0c0;
        --font-sans: "Inter Variable", -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans", Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji";
        --font-display: "JetBrains Mono Variable", ui-monospace, "Cascadia Code", "SF Mono", Menlo, Consolas, monospace;
        --font-mono: "JetBrains Mono Variable", ui-monospace, "Cascadia Code", "SF Mono", Menlo, Consolas, monospace;
        --sl-color-hairline: var(--border);
        --sl-color-gray-2: var(--text-body);
        --sl-color-gray-3: var(--muted);
        --sl-color-gray-4: var(--border-strong);
        --sl-color-white: var(--text);
        --sl-color-text-accent: var(--accent);
    }

    html[data-theme='light'] {
        color-scheme: light;
        --bg: #fafafa;
        --surface: #f1f1f1;
        --surface-2: #e8e8e8;
        --border: #e2e2e2;
        --border-strong: #c9c9c9;
        --text: #171717;
        --muted: #6b6b6b;
        --text-body: #3d3d3d;
        --accent: #171717;
        --accent-hover: #000000;
        --hint: #404040;
        --dir: #404040;
        --ok: #404040;
        --ok-bg: rgba(0, 0, 0, 0.05);
        --ok-border: rgba(0, 0, 0, 0.16);
        --warn: #b45309;
        --danger: #dc2626;
        --done: #404040;
        --shadow: 0 14px 34px rgba(0, 0, 0, 0.08);
        --contrib-0: #e8e8e8;
        --contrib-1: #c9c9c9;
        --contrib-2: #9a9a9a;
        --contrib-3: #5c5c5c;
        --contrib-4: #262626;
        --sl-color-hairline: var(--border);
        --sl-color-gray-2: var(--text-body);
        --sl-color-gray-3: var(--muted);
        --sl-color-gray-4: var(--border-strong);
        --sl-color-white: var(--text);
        --sl-color-text-accent: var(--accent);
    }

    html {
        scroll-behavior: smooth;
        scrollbar-width: thin;
        scrollbar-color: var(--border-strong) var(--bg);
    }

    body {
        font-family: var(--font-mono);
        font-size: 14px;
        line-height: 1.6;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    ::selection {
        background: var(--accent);
        color: var(--bg);
    }

    ::-webkit-scrollbar {
        width: 10px;
        height: 10px;
    }

    ::-webkit-scrollbar-track {
        background: var(--bg);
    }

    ::-webkit-scrollbar-thumb {
        background: var(--border-strong);
        border: 2px solid var(--bg);
        border-radius: 6px;
    }

    ::-webkit-scrollbar-thumb:hover {
        background: var(--muted);
    }

    a {
        color: inherit;
        text-decoration: none;
    }

    a:focus-visible,
    button:focus-visible,
    input:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
    }

    h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-mono);
        font-weight: 700;
        color: var(--text);
    }

    code, kbd, pre, samp {
        font-family: var(--font-mono);
    }

    p {
        font-size: 14px;
        line-height: 1.7;
        color: var(--text-body);
        margin: 0 0 14px 0;
    }

    strong {
        color: var(--text);
        font-weight: 600;
    }

    ul, ol {
        padding-left: 20px;
        margin: 0 0 14px 0;
    }

    li {
        font-size: 13px;
        color: var(--text-body);
        line-height: 1.6;
        margin: 0 0 6px 0;
    }

    li::marker {
        color: var(--muted);
    }

    hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: 24px 0;
    }

    img {
        max-width: 100%;
    }
</style>
