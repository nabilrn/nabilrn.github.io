---
import PortfolioLayout from './PortfolioLayout.astro';
import PortfolioFullLayout from './PortfolioFullLayout.astro';
import {
  authorName,
  getSiteContent,
  localeMeta,
  localizePath,
  normalizeLocale,
  siteUrl,
  stripLocaleFromPath,
  supportedLocales,
  type SiteLocale,
} from '../data/siteContent';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  locale?: SiteLocale;
  lang?: string;
  robots?: string;
  layoutVariant?: 'portfolio' | 'portfolio-full' | 'blog-full';
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  twitterCard?: 'summary' | 'summary_large_image';
  publishedTime?: string;
  modifiedTime?: string;
  articleTags?: string[];
  ogImageWidth?: number;
  ogImageHeight?: number;
  alternatePaths?: Partial<Record<SiteLocale, string>>;
}

const {
  title: pageTitle,
  description: pageDesc,
  path,
  locale: pageLocale,
  lang = 'en',
  robots = 'index, follow',
  layoutVariant = 'portfolio',
  ogImage: pageOgImage,
  ogImageAlt,
  ogType = 'website',
  twitterCard = 'summary_large_image',
  publishedTime,
  modifiedTime,
  articleTags = [],
  ogImageWidth,
  ogImageHeight,
  alternatePaths,
} = Astro.props;

const contentLocale = normalizeLocale(pageLocale ?? lang);
const content = getSiteContent(contentLocale);
const defaultTitle = content.seo.defaultTitle;
const defaultDescription = content.seo.defaultDescription;
const defaultOgImage = '/og/default-og.png';

const title = pageTitle || defaultTitle;
const description = pageDesc || defaultDescription;
const currentUrl = path ? new URL(path, siteUrl).toString() : siteUrl;
const unlocalizedPath = stripLocaleFromPath(path ?? '/');
const htmlLang = localeMeta[contentLocale].htmlLang;
const ogImageUrl = new URL(pageOgImage ?? defaultOgImage, siteUrl).toString();
const ogLocale = localeMeta[contentLocale].ogLocale;
const alternateUrls = supportedLocales.map((localeOption) => ({
  hreflang: localeMeta[localeOption].htmlLang,
  href: new URL(alternatePaths?.[localeOption] ?? localizePath(unlocalizedPath, localeOption), siteUrl).toString(),
}));
const xDefaultPath = alternatePaths?.en ?? unlocalizedPath;
const personJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: authorName,
  alternateName: content.schema.alternateName,
  url: siteUrl,
  email: content.schema.email,
  jobTitle: content.schema.jobTitle,
  description: content.schema.personDescription,
  sameAs: content.schema.sameAs,
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: content.schema.alumniName,
    alternateName: content.schema.alumniAlternateName,
  },
  knowsAbout: content.schema.knowsAbout,
  worksFor: {
    '@type': 'Organization',
    name: content.schema.worksFor,
  },
  nationality: {
    '@type': 'Country',
    name: content.schema.nationality,
  },
});
const websiteJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: authorName,
  alternateName: content.seo.siteAlternateName,
  url: siteUrl,
  publisher: {
    '@type': 'Person',
    name: authorName,
    url: siteUrl,
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteUrl}${localizePath('/blog/', contentLocale)}?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
});
const siteNavigationJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Primary site navigation',
  itemListElement: [
    {
      '@type': 'SiteNavigationElement',
      position: 1,
      name: content.nav.overview,
      url: new URL(localizePath('/', contentLocale), siteUrl).toString(),
    },
    {
      '@type': 'SiteNavigationElement',
      position: 2,
      name: content.nav.projects,
      url: new URL(localizePath('/projects/', contentLocale), siteUrl).toString(),
    },
    {
      '@type': 'SiteNavigationElement',
      position: 3,
      name: content.nav.blog,
      url: new URL(localizePath('/blog/', contentLocale), siteUrl).toString(),
    },
  ],
});
---

<!doctype html>
<html lang={htmlLang}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={authorName} />
    <meta name="keywords" content={content.seo.keywords} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={currentUrl} />
    {alternateUrls.map((item) => <link rel="alternate" hreflang={item.hreflang} href={item.href} />)}
    <link rel="alternate" hreflang="x-default" href={new URL(xDefaultPath, siteUrl).toString()} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    {ogImageWidth && <meta property="og:image:width" content={String(ogImageWidth)} />}
    {ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}
    <meta property="og:site_name" content={content.seo.ogSiteName} />
    <meta property="og:locale" content={ogLocale} />
    {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {ogType === 'article' &&
      articleTags.length > 0 &&
      articleTags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}

    <!-- Twitter -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:url" content={currentUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.svg" />
    <meta name="theme-color" content={content.seo.themeColor} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={personJson}></script>
    <script type="application/ld+json" set:html={websiteJson}></script>
    <script type="application/ld+json" set:html={siteNavigationJson}></script>
</head>
<body>
    {layoutVariant === 'portfolio-full' || layoutVariant === 'blog-full' ? (
        <PortfolioFullLayout currentPath={path} locale={contentLocale} alternatePaths={alternatePaths}>
            <slot />
        </PortfolioFullLayout>
    ) : (
        <PortfolioLayout currentPath={path} locale={contentLocale}>
            <slot />
        </PortfolioLayout>
    )}
</body>
</html>

<style is:global>
    *,
    *::before,
    *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    :root {
        --gh-base: #0d1117;
        --gh-surface: #161b22;
        --gh-surface-2: #21262d;
        --gh-border: #21262d;
        --gh-border-muted: #30363d;
        --gh-text: #e6edf3;
        --gh-text-secondary: #8b949e;
        --gh-text-body: #c9d1d9;
        --gh-accent: #388bfd;
        --gh-accent-hover: #58a6ff;
        --gh-green: #3fb950;
        --gh-green-bg: rgba(35,134,54,0.15);
        --gh-green-border: rgba(35,134,54,0.4);
        --gh-red: #f78166;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: "Mona Sans VF", -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans", Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji";
        font-size: 14px;
        line-height: 1.5;
        background: var(--gh-base);
        color: var(--gh-text);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    a {
        color: inherit;
        text-decoration: none;
    }

    a:focus-visible,
    button:focus-visible,
    input:focus-visible {
        outline: 2px solid var(--gh-accent);
        outline-offset: 2px;
    }

    h1, h2, h3, h4, h5, h6 {
        font-weight: 600;
        color: var(--gh-text);
    }

    p {
        font-size: 14px;
        line-height: 1.7;
        color: var(--gh-text-body);
        margin: 0 0 14px 0;
    }

    strong {
        color: var(--gh-text);
        font-weight: 600;
    }

    ul, ol {
        padding-left: 20px;
        margin: 0 0 14px 0;
    }

    li {
        font-size: 12px;
        color: var(--gh-text-body);
        line-height: 1.5;
        margin: 0 0 6px 0;
    }

    li::marker {
        color: var(--gh-text-secondary);
    }

    hr {
        border: none;
        border-top: 1px solid var(--gh-border);
        margin: 24px 0;
    }

    img {
        max-width: 100%;
    }
</style>
