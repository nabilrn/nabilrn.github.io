---
import ThemeToggle from './ThemeToggle.astro';
import profilePic from '../assets/profilepict.webp';
---

<div class="portfolio-layout">
    <!-- Theme Toggle - Fixed Top Right -->
    <div class="theme-toggle-container">
        <ThemeToggle />
    </div>
    
    <!-- Left Sidebar - Fixed -->
    <aside class="left-sidebar">
        <div class="sidebar-content">
            <div class="profile-section">
                <div class="profile-picture">
                    <img src={profilePic.src} alt="Nabil Rizki Navisa" />
                </div>
                <h1 class="name">Nabil Rizki Navisa</h1>
                <p class="tagline">Software Engineer</p>
                <p class="subtitle">Full-Stack & IT Infrastructure Enthusiast</p>
            </div>
            
            <nav class="nav-links">
                <a href="#about">About</a>
                <a href="#experiences">Experiences</a>
                <a href="#projects">Projects</a>
                <a href="#skills">Skills</a>
            </nav>
            
            <div class="social-links">
                <a href="mailto:nabilrizkinavisa@gmail.com" aria-label="Email" title="Email">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </a>
                <a href="https://github.com/nabilrn" target="_blank" rel="noopener" aria-label="GitHub" title="GitHub">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                </a>
                <a href="https://www.linkedin.com/in/nabilrizkinavisa2004" target="_blank" rel="noopener" aria-label="LinkedIn" title="LinkedIn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
                </a>
                <a href="https://www.instagram.com/nabilrizkinavisa" target="_blank" rel="noopener" aria-label="Instagram" title="Instagram">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                </a>
            </div>
        </div>
    </aside>
    
    <!-- Right Content - Scrollable -->
    <main class="main-content">
        <slot />
    </main>
</div>

<style>
    .portfolio-layout {
        display: flex;
        min-height: 100vh;
        width: 100%;
    }
    
    .theme-toggle-container {
        position: fixed;
        top: 1.5rem;
        right: 1.5rem;
        z-index: 100;
    }
    
    .left-sidebar {
        position: fixed;
        left: 0;
        top: 0;
        width: 30%;
        max-width: 400px;
        min-width: 280px;
        height: 100vh;
        padding: 3rem 2.5rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        border-right: 1px solid var(--sl-color-hairline, #27272a);
        background: var(--sl-color-bg, #09090b);
        z-index: 10;
    }
    
    .sidebar-content {
        display: flex;
        flex-direction: column;
        height: 100%;
        justify-content: space-between;
    }
    
    .profile-section {
        margin-bottom: 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    
    .profile-picture {
        width: 200px;
        height: 200px;
        border-radius: 50%;
        overflow: hidden;
        margin-bottom: 1.5rem;
        border: 3px solid var(--sl-color-hairline, #27272a);
    }
    
    .profile-picture img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    
    .name {
        font-size: 2rem;
        font-weight: 700;
        margin: 0 0 0.5rem 0;
        letter-spacing: -0.02em;
        color: var(--sl-color-white, #fff);
    }
    
    .tagline {
        font-size: 1.1rem;
        font-weight: 500;
        margin: 0 0 0.75rem 0;
        color: var(--sl-color-gray-2, #a1a1aa);
    }
    
    .subtitle {
        font-size: 0.9rem;
        color: var(--sl-color-gray-3, #71717a);
        margin: 0;
        line-height: 1.6;
    }
    
    .nav-links {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        flex-grow: 1;
        padding-top: 2rem;
    }
    
    .nav-links a {
        font-size: 0.85rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--sl-color-gray-3, #71717a);
        text-decoration: none;
        transition: color 0.2s ease;
        padding: 0.25rem 0;
    }
    
    .nav-links a:hover {
        color: var(--sl-color-white, #fff);
    }
    
    .social-links {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-top: 2rem;
        border-top: 1px solid var(--sl-color-hairline, #27272a);
        margin-top: auto;
    }
    
    .social-links a,
    .social-links :global(theme-toggle) {
        color: var(--sl-color-gray-3, #71717a);
        transition: color 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .social-links a:hover {
        color: var(--sl-color-white, #fff);
    }
    
    .main-content {
        margin-left: 30%;
        min-width: 0;
        flex: 1;
        padding: 3rem 4rem;
        max-width: 900px;
    }
    
    /* Mobile Responsive */
    @media (max-width: 900px) {
        .portfolio-layout {
            flex-direction: column;
        }
        
        .left-sidebar {
            position: relative;
            width: 100%;
            max-width: none;
            min-width: auto;
            height: auto;
            padding: 2rem 1.5rem;
            border-right: none;
            border-bottom: 1px solid var(--sl-color-hairline, #27272a);
        }
        
        .sidebar-content {
            gap: 1.5rem;
        }
        
        .nav-links {
            flex-direction: row;
            flex-wrap: wrap;
            gap: 1rem;
            padding-top: 1rem;
        }
        
        .main-content {
            margin-left: 0;
            padding: 2rem 1.5rem;
        }
    }
</style>