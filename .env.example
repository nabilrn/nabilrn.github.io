PUBLIC_ENGAGEMENT_API_BASE=

# GitHub integration for projects section
# Option 1: Set FEATURED_REPOS to specify which repos to display (comma-separated repo names)
#   The build will automatically fetch details (stars, language, description) from GitHub API
# FEATURED_REPOS=Momentum,express-api-starter,moviecatalog-kmp,Airbnb-BI,android-firebase-starter,Outfyt

# Option 2: Set GITHUB_TOKEN to automatically display your actual GitHub pinned repos
#   Generate a token at: https://github.com/settings/tokens (no scopes needed for public repos)
# GITHUB_TOKEN=ghp_xxx
